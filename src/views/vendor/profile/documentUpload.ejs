<% layout('vendor/layout/vendorLayout') %>

<% block('styles', `
    <style>
        .upload-card {
            background: #ffffff;
            color: #1a202c;
            border-radius: 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        .file-drop-zone {
            border: 2px dashed #cbd5e0;
            transition: all 0.3s ease;
        }
        .file-drop-zone:hover {
            border-color: #4299e1;
            background-color: #ebf8ff;
        }
    </style>
`) %>

<div class="p-6 min-h-screen flex items-center justify-center">
    <div class="upload-card w-full max-w-[600px] p-8">
        <!-- Heading -->
        <div class="text-center mb-8">
            <h2 class="text-2xl font-bold text-gray-800">Upload Your Documents</h2>
            <p class="text-gray-500 mt-2">Required for account verification</p>
        </div>

        <!-- Loading Spinner (hidden by default) -->
        <div id="loadingSpinner" class="hidden text-center mb-8">
            <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-gray-200 border-t-blue-600"></div>
            <p class="mt-2 text-sm text-gray-600 font-medium">Uploading documents...</p>
        </div>

        <!-- Form -->
        <form id="uploadForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- GST Document -->
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-700">
                        GST Document <span class="text-blue-500 font-normal">(PDF)</span>
                    </label>
                    <label class="flex flex-col items-center justify-center file-drop-zone rounded-xl py-6 px-4 cursor-pointer">
                        <input type="file" name="gstDocument" accept=".pdf" class="hidden">
                        <i class="fa-solid fa-file-pdf text-3xl text-gray-400 mb-2"></i>
                        <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Choose File</span>
                    </label>
                    <p class="text-xs text-gray-500 mt-2 truncate" id="gstFile">No file selected</p>
                </div>

                <!-- PAN Card -->
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-700">
                        PAN Card <span class="text-blue-500 font-normal">(PDF)</span>
                    </label>
                    <label class="flex flex-col items-center justify-center file-drop-zone rounded-xl py-6 px-4 cursor-pointer">
                        <input type="file" name="panCard" accept=".pdf" class="hidden">
                        <i class="fa-solid fa-id-card text-3xl text-gray-400 mb-2"></i>
                        <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Choose File</span>
                    </label>
                    <p class="text-xs text-gray-500 mt-2 truncate" id="panFile">No file selected</p>
                </div>
            </div>

            <!-- Trade License -->
            <div>
                <label class="block text-sm font-semibold mb-2 text-gray-700">
                    Trade License <span class="text-blue-500 font-normal">(PDF)</span>
                </label>
                <label class="flex flex-col items-center justify-center file-drop-zone rounded-xl py-8 cursor-pointer">
                    <input type="file" name="tradeLicense" accept=".pdf" class="hidden">
                    <i class="fa-solid fa-file-signature text-4xl text-gray-400 mb-3"></i>
                    <span class="text-sm font-bold text-gray-600 uppercase tracking-wider">Upload Trade License</span>
                </label>
                <p class="text-xs text-center text-gray-500 mt-2" id="licenseFile">No file selected</p>
            </div>

            <!-- Notes -->
            <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 flex gap-3">
                <i class="fa-solid fa-circle-info text-blue-500 mt-1"></i>
                <div>
                    <p class="text-xs text-gray-600 leading-relaxed">
                        <strong>Requirements:</strong> Maximum file size 5MB per document. Ensure documents are clearly readable. Only PDF format is accepted.
                    </p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4 pt-4">
                <button type="reset" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-600 py-3 rounded-xl font-bold transition-all border border-gray-200">
                    Reset
                </button>
                <button type="submit" id="submitBtn" class="flex-2 bg-blue-600 hover:bg-blue-700 text-white px-10 py-3 rounded-xl font-bold transition-all shadow-lg shadow-blue-200 disabled:opacity-50">
                    Upload All Documents
                </button>
            </div>
        </form>
    </div>
</div>

<% block('scripts', `
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('uploadForm');
            const submitBtn = document.getElementById('submitBtn');
            const loadingSpinner = document.getElementById('loadingSpinner');

            const fileInputs = {
                gstDocument: document.querySelector('input[name="gstDocument"]'),
                panCard: document.querySelector('input[name="panCard"]'),
                tradeLicense: document.querySelector('input[name="tradeLicense"]')
            };

            Object.entries(fileInputs).forEach(([name, input]) => {
                input.addEventListener('change', (e) => {
                    const fileName = e.target.files[0]?.name || 'No file selected';
                    const displayId = name === 'tradeLicense' ? 'licenseFile' : 
                                    (name === 'gstDocument' ? 'gstFile' : 'panFile');
                    document.getElementById(displayId).textContent = fileName;
                });
            });

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const files = form.querySelectorAll('input[type="file"]');
                const hasFile = Array.from(files).some(input => input.files.length > 0);

                if (!hasFile) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'No Files Selected',
                        text: 'Please select at least one document to upload',
                        confirmButtonColor: '#2563eb',
                        background: '#1f2937',
                        color: '#fff'
                    });
                    return;
                }

                submitBtn.disabled = true;
                loadingSpinner.classList.remove('hidden');

                Swal.fire({
                    title: 'Uploading Documents',
                    text: 'Please wait...',
                    allowOutsideClick: false,
                    background: '#1f2937',
                    color: '#fff',
                    didOpen: () => Swal.showLoading()
                });

                try {
                    const formData = new FormData(form);
                    const response = await fetch('/vendor/profile/uploads', {
                        method: 'POST',
                        body: formData,
                        credentials: 'include'
                    });

                    const data = await response.json();
                    if (!response.ok) throw new Error(data.message || 'Upload failed');

                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Documents uploaded successfully. Admin will verify them shortly.',
                        confirmButtonText: 'Go to Profile',
                        confirmButtonColor: '#10b981',
                        background: '#1f2937',
                        color: '#fff'
                    }).then(() => {
                        window.location.href = '/vendor/profile';
                    });
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Upload Failed',
                        text: error.message,
                        confirmButtonColor: '#ef4444',
                        background: '#1f2937',
                        color: '#fff'
                    });
                } finally {
                    submitBtn.disabled = false;
                    loadingSpinner.classList.add('hidden');
                }
            });

            form.addEventListener('reset', () => {
                ['licenseFile', 'gstFile', 'panFile'].forEach(id => {
                    document.getElementById(id).textContent = 'No file selected';
                });
            });
        });
    </script>
`) %>