<% layout('vendor/layout/vendorLayout') %>

<% block('styles', `
    <style>
        .table-container::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .table-container::-webkit-scrollbar-track {
            background: #0a1425;
        }
        .table-container::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 3px;
        }
        .table-container::-webkit-scrollbar-thumb:hover {
            background: #374151;
        }
    </style>
`) %>

<div class="p-6 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 bg-primary/50 backdrop-blur-md p-6 rounded-xl border border-gray-800 sticky top-4 z-20 gap-4">
        <div>
            <h1 class="text-2xl font-bold">Order List</h1>
            <p class="text-gray-400 text-sm mt-1">Manage your orders and track shipments</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
            <!-- Status Filter -->
            <div class="relative group min-w-[180px]">
                <select id="statusFilter" onchange="filterStatus(this.value)"
                        class="w-full bg-[#0a1425] border border-gray-800 text-gray-400 rounded-lg py-2.5 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 appearance-none cursor-pointer transition-all pr-10">
                    <option value="">All Statuses</option>
                    <% ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled', 'returned'].forEach(s => { %>
                        <option value="<%= s %>" <%= (typeof status !== 'undefined' && status === s) ? 'selected' : '' %>>
                            <%= s.charAt(0).toUpperCase() + s.slice(1) %>
                        </option>
                    <% }) %>
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
            </div>
            
            <button class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-all flex items-center gap-2 shadow-lg shadow-blue-900/20">
                <i class="fa-solid fa-download text-xs"></i> Export
            </button>
        </div>
    </header>

    <!-- Stats Overview -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-primary/40 p-4 rounded-xl border border-gray-800">
            <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Total Orders</p>
            <h3 class="text-2xl font-bold mt-1"><%= totalOrders %></h3>
        </div>
        <div class="bg-primary/40 p-4 rounded-xl border border-gray-800">
            <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Pending</p>
            <h3 class="text-2xl font-bold mt-1 text-yellow-500"><%= orders.filter(o => o.orderStatus === 'pending').length %></h3>
        </div>
        <div class="bg-primary/40 p-4 rounded-xl border border-gray-800">
            <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Delivered</p>
            <h3 class="text-2xl font-bold mt-1 text-green-500"><%= orders.filter(o => o.orderStatus === 'delivered').length %></h3>
        </div>
        <div class="bg-primary/40 p-4 rounded-xl border border-gray-800">
            <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Cancelled</p>
            <h3 class="text-2xl font-bold mt-1 text-red-500"><%= orders.filter(o => o.orderStatus === 'cancelled').length %></h3>
        </div>
    </div>

    <!-- Table Section -->
    <div class="bg-primary/40 rounded-2xl border border-gray-800 overflow-hidden flex-1 flex flex-col">
        <div class="table-container overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-800/50">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800">Order ID</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800">Date</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800">Customer</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800">Status</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800">Amount</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400 border-b border-gray-800 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    <% if (orders && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr class="hover:bg-gray-800/30 transition-colors group">
                                <td class="px-6 py-4">
                                    <span class="font-mono text-blue-400 font-medium">#<%= order._id.toString().slice(-6).toUpperCase() %></span>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </td>
                                <td class="px-6 py-4 text-sm font-medium">
                                    <%=  order.address.name %>
                                </td>
                                <td class="px-6 py-4">
                                    <% 
                                        let statusClass = '';
                                        switch(order.orderStatus) {
                                            case 'pending': statusClass = 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20'; break;
                                            case 'processing': statusClass = 'bg-blue-500/10 text-blue-500 border-blue-500/20'; break;
                                            case 'shipped': statusClass = 'bg-purple-500/10 text-purple-500 border-purple-500/20'; break;
                                            case 'delivered': statusClass = 'bg-green-500/10 text-green-500 border-green-500/20'; break;
                                            case 'cancelled': statusClass = 'bg-red-500/10 text-red-500 border-red-500/20'; break;
                                            case 'returned': statusClass = 'bg-gray-500/10 text-gray-400 border-gray-500/20'; break;
                                            default: statusClass = 'bg-gray-500/10 text-gray-400 border-gray-500/20';
                                        }
                                    %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= statusClass %>">
                                        <%= order.orderStatus.charAt(0).toUpperCase() + order.orderStatus.slice(1) %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 font-semibold">
                                    ₹<%= (order.total || 0).toFixed(1) %>
                                </td>

                                <td class="px-6 py-4 text-right">
                                    <a href="/vendor/orders/<%= order._id %>" 
                                       class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 text-gray-400 hover:bg-blue-600 hover:text-white transition-all">
                                        <i class="fa-solid fa-eye text-xs"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                                <i class="fa-solid fa-box-open text-4xl mb-4 block opacity-20"></i>
                                No orders found
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gray-800">
            <p class="text-sm text-gray-400">
                Showing <span class="font-medium text-white"><%= orders.length %></span> orders of <span class="font-medium text-white"><%= (typeof totalOrders !== 'undefined' ? totalOrders : orders.length) %></span>
            </p>
            <div class="flex items-center gap-2">
                <button onclick="goToPage(<%= currentPage - 1 %>)" 
                        <%= (typeof currentPage !== 'undefined' && currentPage === 1) ? 'disabled' : '' %>
                        class="px-4 py-2 rounded-lg bg-gray-800 text-gray-400 hover:text-white disabled:opacity-50 disabled:cursor-not-allowed text-xs transition-all font-medium border border-gray-700">
                    Previous
                </button>
                
                <div class="flex items-center gap-1">
                    <% for(let i = 1; i <= (typeof totalPages !== 'undefined' ? totalPages : 1); i++) { %>
                        <button onclick="goToPage(<%= i %>)"
                                class="w-8 h-8 rounded-lg flex items-center justify-center text-xs transition-all font-medium <%= (typeof currentPage !== 'undefined' && currentPage === i) ? 'bg-blue-600 text-white shadow-lg shadow-blue-900/40' : 'bg-gray-800 text-gray-400 hover:text-white hover:bg-gray-700 border border-gray-700' %>">
                            <%= i %>
                        </button>
                    <% } %>
                </div>

                <button onclick="goToPage(<%= currentPage + 1 %>)"
                        <%= (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage === totalPages) ? 'disabled' : '' %>
                        class="px-4 py-2 rounded-lg bg-gray-800 text-gray-400 hover:text-white disabled:opacity-50 disabled:cursor-not-allowed text-xs transition-all font-medium border border-gray-700">
                    Next
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function goToPage(page) {
        const url = new URL(window.location.href);
        url.searchParams.set('page', page);
        window.location.href = url.toString();
    }

    function filterStatus(status) {
        const url = new URL(window.location.href);
        if (status) {
            url.searchParams.set('status', status);
        } else {
            url.searchParams.delete('status');
        }
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    }
    
</script>