<% layout('vendor/layout/vendorLayout') %>

<% block('styles', `
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
    <style>
        .custom-dark-card {
            background-color: #0a1425;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .input-dark {
            background-color: #f3f4f6;
            color: #1f2937;
        }
        .input-outline-dark {
            background-color: transparent;
            border: 1px solid #1e293b;
            color: white;
        }
        .error-message {
            color: #ef4444;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
`) %>

<div class="px-8 md:p-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center space-x-1 text-sm text-gray-400 mb-6">
        <a href="/vendor/dashboard" class="hover:text-gray-200 transition-colors">Dashboard</a>
        <span class="mx-2">&gt;</span>
        <a href="/vendor/products" class="hover:text-gray-200 transition-colors">Products</a>
        <span class="mx-2">&gt;</span>
        <span class="text-gray-200">Edit Product</span>
    </nav>

    <h2 class="text-2xl font-bold mb-8">Product Details</h2>

    <form action="/vendor/products/<%= productId %>/edit" method="POST" enctype="multipart/form-data" id="productForm" class="space-y-12 pb-12">
        <!-- Section 1: General Information -->
        <div class="custom-dark-card rounded-3xl p-8 md:p-10 shadow-xl space-y-8">
            <h3 class="text-xl font-semibold">General Information</h3>
            
            <div class="space-y-6">
                <!-- Product Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Product Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" required placeholder="Enter product name"
                           value="<%= name || '' %>"
                           class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.name ? 'border-2 border-red-500' : '' %>">
                    <% if (locals.errors?.name) { %>
                        <p class="error-message"><%= locals.errors.name %></p>
                    <% } %>
                </div>

                <!-- Brand Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Brand Name <span class="text-red-500">*</span></label>
                    <input type="text" name="brand" required placeholder="Enter brand name"
                           value="<%= brand || '' %>"
                           class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.brand ? 'border-2 border-red-500' : '' %>">
                    <% if (locals.errors?.brand) { %>
                        <p class="error-message"><%= locals.errors.brand %></p>
                    <% } %>
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Description <span class="text-red-500">*</span></label>
                    <textarea name="description" rows="5" required placeholder="Enter product description"
                              class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.description ? 'border-2 border-red-500' : '' %>"><%= description || '' %></textarea>
                    <% if (locals.errors?.description) { %>
                        <p class="error-message"><%= locals.errors.description %></p>
                    <% } %>
                </div>

                <!-- Category -->
                <div class="w-full md:w-1/2">
                    <label class="block text-sm font-medium text-gray-300 mb-4">Select Category <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <select name="category" required class="w-full bg-white border border-gray-700 text-black px-4 py-3 rounded-lg appearance-none focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.category ? 'border-2 border-red-500' : '' %>">
                            <option value="">Select a category</option>
                            <% if (categories && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat._id %>" <%= (cat && cat.toString() === cat._id.toString()) ? 'selected' : '' %>><%= cat.categoryName %></option>
                                <% }); %>
                            <% } %>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                            <i class="fa-solid fa-chevron-down text-sm"></i>
                        </div>
                    </div>
                    <% if (locals.errors?.category) { %>
                        <p class="error-message"><%= locals.errors.category %></p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Section 2: Product Variants -->
        <div id="variants-container" class="space-y-12">
            <% 
            let variantsToShow = (variants && variants.length > 0) ? variants : [{}];
            variantsToShow.forEach((variant, index) => { 
            %>
            <div class="variant-section custom-dark-card rounded-3xl p-8 md:p-10 shadow-xl space-y-10 relative group" data-variant-index="<%= index %>">
                <!-- Remove button -->
                <button type="button" class="remove-variant-btn absolute top-8 right-8 text-red-500 hover:text-red-700 <%= (index === 0 && variantsToShow.length === 1) ? 'hidden' : '' %>">
                    <i class="fa-solid fa-trash-can text-xl"></i>
                </button>
                
                <h3 class="text-lg font-bold uppercase tracking-widest text-gray-300">PRODUCT VARIANT <span class="variant-number"><%= index + 1 %></span></h3>
                
                <div class="space-y-10">
                    <!-- Photos Section -->
                    <div class="space-y-6">
                        <h4 class="text-sm font-medium text-gray-400">Main Photo <span class="text-red-500">*</span></h4>
                        
                        <!-- Main Image Upload -->
                        <div class="w-full max-w-2xl mx-auto bg-white rounded-xl p-12 text-center border-2 border-dashed border-gray-300 flex flex-col items-center justify-center space-y-4 relative overflow-hidden group min-h-[300px]">
                            <% if (variant.mainImage && variant.mainImage.url) { %>
                                <input type="hidden" name="variants[<%= index %>][existingMainImage]" value="<%= variant.mainImage.publicId %>">
                            <% } %>

                            <input type="file" name="variants[<%= index %>][mainImage]" <%= (variant.mainImage && variant.mainImage.url) ? '' : 'required' %> class="hidden main-image-input" accept="image/*">
                            
                            <div class="preview-container absolute inset-0 <%= (variant.mainImage && variant.mainImage.url) ? '' : 'hidden' %>">
                                <img src="<%= variant.mainImage ? variant.mainImage.url : '' %>" alt="Preview" class="w-full h-full object-contain">
                            </div>
                            
                            <div class="upload-placeholder flex flex-col items-center space-y-4 <%= (variant.mainImage && variant.mainImage.url) ? 'opacity-0' : '' %>">
                                <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center">
                                    <i class="fa-solid fa-image text-indigo-500 text-xl"></i>
                                </div>
                                <p class="text-sm text-gray-500">Drag and drop image here, or click add image</p>
                            </div>
                            <button type="button" class="upload-btn px-6 py-2 bg-indigo-100 text-indigo-600 font-semibold rounded-lg hover:bg-indigo-200 transition-colors z-10">
                                <%= (variant.mainImage && variant.mainImage.url) ? 'Change Image' : 'Upload Image' %>
                            </button>
                        </div>

                        <h4 class="text-sm font-medium text-gray-400">Additional Images <span class="text-red-500">*</span></h4>
                        
                        <!-- Additional Images Grid -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                            <% for(let i=0; i<3; i++) { 
                                const existingImg = (variant.additionalImages && variant.additionalImages[i]);
                            %>
                            <div class="bg-white rounded-xl p-6 text-center border border-gray-200 flex flex-col items-center justify-center space-y-3 relative overflow-hidden group h-40">
                                <% if (existingImg && existingImg.url) { %>
                                    <input type="hidden" name="variants[<%= index %>][existingAdditionalImages][<%= i %>]" value="<%= existingImg.publicId %>">
                                <% } %>

                                <input type="file" name="variants[<%= index %>][additionalImages][<%= i %>]" class="hidden additional-image-input" <%= (existingImg && existingImg.url) ? '' : 'required' %> accept="image/*">
                                
                                <div class="preview-container absolute inset-0 <%= (existingImg && existingImg.url) ? '' : 'hidden' %>">
                                    <img src="<%= existingImg ? existingImg.url : '' %>" alt="Preview" class="w-full h-full object-contain">
                                </div>
                                
                                <div class="upload-placeholder flex flex-col items-center space-y-3 <%= (existingImg && existingImg.url) ? 'opacity-0' : '' %>">
                                    <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                                        <i class="fa-solid fa-image text-indigo-500"></i>
                                    </div>
                                    <p class="text-[10px] text-gray-500 leading-tight">Drag and drop image here</p>
                                </div>
                                <button type="button" class="upload-btn px-4 py-1.5 bg-indigo-100 text-indigo-600 text-xs font-bold rounded-lg hover:bg-indigo-200 transition-colors z-10">
                                    <%= (existingImg && existingImg.url) ? 'Change' : 'Upload Image' %>
                                </button>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Variant Details Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Color <span class="text-red-500">*</span></label>
                            <input type="text" name="variants[<%= index %>][color]" required placeholder="Ex. Black, Silver"
                                   value="<%= variant.color || '' %>"
                                   class="w-full input-outline-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500 <%= locals.errors?.['variants.' + index + '.color'] ? 'border-red-500' : '' %>">
                            <% if (locals.errors?.['variants.' + index + '.color']) { %>
                                <p class="error-message"><%= locals.errors['variants.' + index + '.color'] %></p>
                            <% } %>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Strap Material <span class="text-red-500">*</span></label>
                            <input type="text" name="variants[<%= index %>][strapMaterial]" required placeholder="Ex. Leather, Metal, Silicone"
                                   value="<%= variant.strapMaterial || '' %>"
                                   class="w-full input-outline-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500 <%= locals.errors?.['variants.' + index + '.strapMaterial'] ? 'border-red-500' : '' %>">
                            <% if (locals.errors?.['variants.' + index + '.strapMaterial']) { %>
                                <p class="error-message"><%= locals.errors['variants.' + index + '.strapMaterial'] %></p>
                            <% } %>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Price (₹) <span class="text-red-500">*</span></label>
                            <input type="number" name="variants[<%= index %>][price]" required min="0" step="0.01" placeholder="Ex. 5000"
                                   value="<%= variant.price || '' %>"
                                   class="w-full input-outline-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500 <%= locals.errors?.['variants.' + index + '.price'] ? 'border-red-500' : '' %>">
                            <% if (locals.errors?.['variants.' + index + '.price']) { %>
                                <p class="error-message"><%= locals.errors['variants.' + index + '.price'] %></p>
                            <% } %>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Quantity <span class="text-red-500">*</span></label>
                            <input type="number" name="variants[<%= index %>][quantity]" required min="0" step="1"
                                   value="<%= variant.quantity || '' %>"
                                   class="w-full input-outline-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500 <%= locals.errors?.['variants.' + index + '.quantity'] ? 'border-red-500' : '' %>">
                            <% if (locals.errors?.['variants.' + index + '.quantity']) { %>
                                <p class="error-message"><%= locals.errors['variants.' + index + '.quantity'] %></p>
                            <% } %>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Offer (%)</label>
                            <input type="number" name="variants[<%= index %>][offer]" min="0" max="100" placeholder="Ex. 10" 
                                   value="<%= variant.offer || 0 %>"
                                   class="w-full input-outline-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500 <%= locals.errors?.['variants.' + index + '.offer'] ? 'border-red-500' : '' %>">
                            <% if (locals.errors?.['variants.' + index + '.offer']) { %>
                                <p class="error-message"><%= locals.errors['variants.' + index + '.offer'] %></p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>

        <!-- Add Variant Button -->
        <div class="flex justify-center">
            <button type="button" id="add-variant-btn" class="px-10 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-lg">
                <i class="fa-solid fa-plus mr-2"></i>ADD ANOTHER VARIANT
            </button>
        </div>

        <!-- Section 3: Product Specifications -->
        <div class="space-y-6">
            <h3 class="text-xl font-semibold">Product Specifications</h3>
            <div class="custom-dark-card rounded-3xl p-8 md:p-10 shadow-xl space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Weight <span class="text-red-500">*</span></label>
                        <input type="text" name="specifications[weight]" required placeholder="Ex. 150g, 0.15kg"
                               value="<%= specifications?.weight || '' %>"
                               class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.['specifications.weight'] ? 'border-2 border-red-500' : '' %>">
                        <% if (locals.errors?.['specifications.weight']) { %>
                            <p class="error-message"><%= locals.errors['specifications.weight'] %></p>
                        <% } %>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Water Resistance <span class="text-red-500">*</span></label>
                        <input type="text" name="specifications[waterResistance]" required placeholder="Ex. 50m, 100m, 5ATM"
                               value="<%= specifications?.waterResistance || '' %>"
                               class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.['specifications.waterResistance'] ? 'border-2 border-red-500' : '' %>">
                        <% if (locals.errors?.['specifications.waterResistance']) { %>
                            <p class="error-message"><%= locals.errors['specifications.waterResistance'] %></p>
                        <% } %>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Warranty <span class="text-red-500">*</span></label>
                        <input type="text" name="specifications[warranty]" required placeholder="Ex. 1 year, 2 years"
                               value="<%= specifications?.warranty || '' %>"
                               class="w-full input-dark px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 <%= locals.errors?.['specifications.warranty'] ? 'border-2 border-red-500' : '' %>">
                        <% if (locals.errors?.['specifications.warranty']) { %>
                            <p class="error-message"><%= locals.errors['specifications.warranty'] %></p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Final Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4 pt-8">
            <button type="submit" id="submitBtn" class="w-full sm:w-auto px-16 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
                <i class="fa-solid fa-check mr-2"></i>SAVE CHANGES
            </button>
            <a href="/vendor/products" class="w-full sm:w-auto px-16 py-4 bg-gray-800 text-white font-bold border border-gray-700 rounded-xl hover:bg-gray-700 transition-colors text-center">
                <i class="fa-solid fa-times mr-2"></i>CANCEL
            </a>
        </div>
    </form>
</div>

<!-- Crop Modal -->
<div id="cropModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-gray-900 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-[#0a1425] rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-3xl sm:w-full border border-gray-700">
            <div class="px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-white mb-4" id="modal-title">Crop Image</h3>
                        <div class="max-h-[500px] w-full bg-black flex items-center justify-center overflow-hidden rounded-lg">
                            <img id="cropImage" src="" alt="Image to crop" class="max-w-full">
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-800 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-700">
                <button type="button" id="cropBtn" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                    Crop & Save
                </button>
                <button type="button" id="cancelCropBtn" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-600 shadow-sm px-4 py-2 bg-transparent text-base font-medium text-gray-300 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<% block('scripts', `
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
`) %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const successMsg = <%- JSON.stringify(locals.success || "") %>;
        const errorMsg = <%- JSON.stringify(locals.error || "") %>;

        if (successMsg) {
            Swal.fire({ icon: 'success', title: 'Success!', text: successMsg, background: '#0a1425', color: '#fff', confirmButtonColor: '#2563eb' });
        }
        if (errorMsg) {
            Swal.fire({ icon: 'error', title: 'Error!', text: errorMsg, background: '#0a1425', color: '#fff', confirmButtonColor: '#ef4444' });
        }

        const container = document.getElementById('variants-container');
        const addBtn = document.getElementById('add-variant-btn');
        const form = document.getElementById('productForm');
        const submitBtn = document.getElementById('submitBtn');
        let variantCount = document.querySelectorAll('.variant-section').length;

        let cropper, currentInput, currentPreviewImg, currentPlaceholder, currentBtn;
        const cropModal = document.getElementById('cropModal');
        const cropImage = document.getElementById('cropImage');
        const cropBtn = document.getElementById('cropBtn');
        const cancelCropBtn = document.getElementById('cancelCropBtn');

        function initUploadLogic(scope) {
            scope.querySelectorAll('.upload-btn').forEach(btn => {
                const parent = btn.closest('.bg-white, .max-w-2xl');
                const input = parent.querySelector('input[type="file"]');
                const preview = parent.querySelector('.preview-container');
                const img = preview.querySelector('img');
                const placeholder = parent.querySelector('.upload-placeholder');

                btn.onclick = () => input.click();

                input.onchange = (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    if (!file.type.startsWith('image/')) {
                        Swal.fire({ icon: 'error', title: 'Invalid File', text: 'Please upload an image file', background: '#0a1425', color: '#fff' });
                        input.value = '';
                        return;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        Swal.fire({ icon: 'error', title: 'File Too Large', text: 'Image size should not exceed 5MB', background: '#0a1425', color: '#fff' });
                        input.value = '';
                        return;
                    }
                    currentInput = input;
                    currentPreviewImg = img;
                    currentPlaceholder = placeholder;
                    currentBtn = btn;
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        cropImage.src = event.target.result;
                        cropModal.classList.remove('hidden');
                        if (cropper) cropper.destroy();
                        cropper = new Cropper(cropImage, { aspectRatio: 1, viewMode: 1, autoCropArea: 1 });
                    };
                    reader.readAsDataURL(file);
                };
            });
        }

        cropBtn.addEventListener('click', () => {
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            canvas.toBlob((blob) => {
                const fileName = currentInput.files[0].name;
                const newFile = new File([blob], fileName, { type: 'image/jpeg' });
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(newFile);
                currentInput.files = dataTransfer.files;
                currentPreviewImg.src = URL.createObjectURL(blob);
                currentPreviewImg.closest('.preview-container').classList.remove('hidden');
                currentPlaceholder.classList.add('opacity-0');
                currentBtn.textContent = 'Change Image';
                cropModal.classList.add('hidden');
                cropper.destroy();
                cropper = null;
            }, 'image/jpeg');
        });

        cancelCropBtn.addEventListener('click', () => {
            cropModal.classList.add('hidden');
            if (cropper) { cropper.destroy(); cropper = null; }
            currentInput.value = '';
        });

        initUploadLogic(document);

        addBtn.addEventListener('click', () => {
            const original = document.querySelector('.variant-section');
            const clone = original.cloneNode(true);
            const newIndex = variantCount;

            clone.dataset.variantIndex = newIndex;
            clone.querySelector('.variant-number').textContent = newIndex + 1;

            const removeBtn = clone.querySelector('.remove-variant-btn');
            removeBtn.classList.remove('hidden');
            removeBtn.onclick = () => { clone.remove(); reindexVariants(); };

            // Remove all hidden existing-image inputs — new variant has no existing images
            clone.querySelectorAll('input[type="hidden"]').forEach(input => input.remove());

            // Fix all input names with global replace, reset values
            clone.querySelectorAll('input').forEach(input => {
                if (input.name) {
                    input.name = input.name.replace(/variants\[\d+\]/g, 'variants[' + newIndex + ']');
                }
                if (input.type === 'file') {
                    input.value = '';
                    input.required = true;
                } else {
                    input.value = (input.name && input.name.includes('offer')) ? '0' : '';
                }
                input.classList.remove('border-red-500', 'border-2');
            });

            clone.querySelectorAll('.error-message').forEach(err => err.remove());
            clone.querySelectorAll('.preview-container').forEach(pc => {
                pc.classList.add('hidden');
                const img = pc.querySelector('img');
                if (img) img.src = '';
            });
            clone.querySelectorAll('.upload-placeholder').forEach(up => up.classList.remove('opacity-0'));
            clone.querySelectorAll('.upload-btn').forEach(ub => { ub.textContent = 'Upload Image'; });

            container.appendChild(clone);
            initUploadLogic(clone);
            variantCount++;
        });

        function reindexVariants() {
            const variants = document.querySelectorAll('.variant-section');
            variantCount = variants.length;
            variants.forEach((v, index) => {
                v.dataset.variantIndex = index;
                v.querySelector('.variant-number').textContent = index + 1;

                // Fix names with global replace
                v.querySelectorAll('input').forEach(input => {
                    if (input.name) {
                        input.name = input.name.replace(/variants\[\d+\]/g, 'variants[' + index + ']');
                    }
                });

                const removeBtn = v.querySelector('.remove-variant-btn');
                if (index === 0) {
                    removeBtn.classList.add('hidden');
                } else {
                    removeBtn.classList.remove('hidden');
                }
            });
        }

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            const variantSections = document.querySelectorAll('.variant-section');
            let isValid = true;
            let errorMessages = [];

            variantSections.forEach((variant, index) => {
                const mainImageInput = variant.querySelector('.main-image-input');
                const existingMainImage = variant.querySelector('input[name*="existingMainImage"]');
                const hasMainImage = (mainImageInput.files && mainImageInput.files.length > 0) || (existingMainImage && existingMainImage.value);
                if (!hasMainImage) {
                    isValid = false;
                    errorMessages.push('Variant ' + (index + 1) + ': Please upload a main image');
                }

                let additionalCount = 0;
                variant.querySelectorAll('.additional-image-input').forEach(input => {
                    const parent = input.closest('div');
                    const existingAdditional = parent.querySelector('input[type="hidden"]');
                    if ((input.files && input.files.length > 0) || (existingAdditional && existingAdditional.value)) {
                        additionalCount++;
                    }
                });
                if (additionalCount < 3) {
                    isValid = false;
                    errorMessages.push('Variant ' + (index + 1) + ': Please upload all 3 additional images');
                }
            });

            if (!isValid) {
                Swal.fire({ icon: 'error', title: 'Missing Images', html: errorMessages.join('<br>'), background: '#0a1425', color: '#fff' });
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>UPDATING...';
            form.submit();
        });
    });
</script>