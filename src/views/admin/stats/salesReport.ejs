<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 700;
            color: #ffffff;
            padding-bottom: 2rem;
            text-decoration: underline;
        }
        
        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background-color: #0f1e2e;
            border: 1px solid #1a2d4a;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: transform 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            border-color: #2d5a8c;
        }
        .stat-label {
            font-size: 13px;
            color: #b0c4de;
            font-weight: 500;
        }
        .stat-value {
            font-size: 24px;
            font-weight: 600;
            color: #ffffff;
        }
        .stat-value.highlight {
            color: #3b82f6;
        }
        .stat-value.positive {
            color: #22c55e;
        }
        
        /* Filters */
        .controls-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            gap: 20px;
            flex-wrap: wrap;
        }
        .filters-group {
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }
        .filter-label {
            font-size: 13px;
            font-weight: 500;
            color: #b0c4de;
        }
        .filter-dropdown {
            padding: 8px 12px;
            border: 1px solid #1a2d4a;
            border-radius: 6px;
            background-color: #000B1B;
            color: #ffffff;
            cursor: pointer;
            font-size: 13px;
            min-width: 140px;
        }
        .filter-dropdown:focus {
            outline: none;
            border-color: #4a7ba7;
        }
        .date-input {
            padding: 8px 12px;
            border: 1px solid #1a2d4a;
            border-radius: 6px;
            background-color: #000B1B;
            color: #ffffff;
            font-size: 13px;
        }
        .action-btn {
            background-color: #2d5a8c;
            color: #ffffff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: background-color 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .action-btn:hover {
            background-color: #3d6fa8;
        }
        .action-btn.secondary {
            background-color: transparent;
            border: 1px solid #2d5a8c;
        }
        .action-btn.secondary:hover {
            background-color: #1a2d4a;
        }

        /* Table */
        .table-container {
            overflow-x: auto;
            background-color: #0f1e2e;
            border-radius: 8px;
            border: 1px solid #1a2d4a;
            margin-bottom: 30px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            background-color: #1a3a52;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            font-size: 13px;
            color: #ffffff;
            border-bottom: 1px solid #0f2438;
        }
        td {
            padding: 15px;
            border-bottom: 1px solid #0f2438;
            font-size: 13px;
            color: #b0c4de;
        }
        tr:hover {
            background-color: #0a1425;
        }
        
        /* Pagination */
        .pagination {
            display: flex;
            justify-content: end;
            gap: 8px;
            margin-top: 20px;
        }
        .pagination button {
            width: 36px;
            height: 36px;
            border: 1px solid #1a2d4a;
            background-color: transparent;
            color: #b0c4de;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }
        .pagination button:hover:not(:disabled) {
            background-color: #1a2d4a;
            color: #ffffff;
        }
        .pagination button.active {
            background-color: #2d5a8c;
            color: #ffffff;
            border-color: #2d5a8c;
        }
        .pagination button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .pagination-info {
            text-align: left;
            font-size: 12px;
            color: #6b7c93;
            margin-top: 15px;
        }
    </style>
`) %>

<div class="p-8">
    <!-- Breadcrumb -->
    <div class="breadcrumb text-sm text-gray-400 mb-4">
        <a href="/admin/dashboard" class="hover:text-white">Dashboard</a> > <span class="text-white">Sales Report</span>
    </div>
    
    <div>
        <h1 class="page-title">Sales Report</h1>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label"><i class="fa-solid fa-cart-shopping mr-2"></i>Total Orders</span>
            <span class="stat-value"><%= totalOrders || 0 %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label"><i class="fa-solid fa-indian-rupee-sign mr-2"></i>Gross Revenue</span>
            <span class="stat-value highlight">₹<%= grossRevenue || '0.00' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label"><i class="fa-solid fa-tag mr-2"></i>Total Discount</span>
            <span class="stat-value">₹<%= totalDiscount || '0.00' %></span>
        </div>
        <div class="stat-card">
            <span class="stat-label"><i class="fa-solid fa-wallet mr-2"></i>Net Revenue</span>
            <span class="stat-value positive">₹<%= netRevenue || '0.00' %></span>
        </div>
        <!-- Additional stats from previous sidebar -->
        <div class="stat-card">
             <span class="stat-label"><i class="fa-solid fa-truck mr-2"></i>Delivery Charges (Est.)</span>
             <span class="stat-value">₹<%= deliveryCharges || '0.00' %></span>
        </div>
    </div>

    <!-- Controls & Filters -->
    <div class="controls-row">
        <!-- Filters -->
        <div class="filters-group">
            <label class="filter-label">Period:</label>
            <select id="periodFilter" class="filter-dropdown" onchange="toggleCustomDate()">
                <option value="daily">Daily</option>
                <option value="weekly">Weekly</option>
                <option value="monthly">Monthly</option>
                <option value="yearly">Yearly</option>
                <option value="custom">Custom Range</option>
            </select>
            
<div id="customDateContainer" class="filters-group" style="display: none; align-items:center; gap:10px;">
    
    <span class="filter-label">Starting Date:</span>
    <input type="date" id="dateFrom" class="date-input">

    <span class="filter-label">Ending Date:</span>
    <input type="date" id="dateTo" class="date-input">

</div>

            
            <button class="action-btn" onclick="applyFilters()">
                <i class="fa-solid fa-filter"></i> Apply
            </button>
        </div>

        <!-- Downloads -->
        <div class="filters-group">
            <button class="action-btn secondary" onclick="downloadReport('pdf')">
                <i class="fa-solid fa-file-pdf"></i> PDF
            </button>
            <button class="action-btn secondary" onclick="downloadReport('excel')">
                <i class="fa-solid fa-file-excel"></i> Excel
            </button>
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Order ID</th>
                    <th>Payment Method</th>
                    <th>Gross Sales</th>
                    <th>Discount</th>
                    <th>Net Sales</th>
                </tr>
            </thead>
            <tbody>
                <% if (salesDatas && salesDatas.length > 0) { %>
                    <% salesDatas.forEach(sale => { %>
                        <tr>
                            <td><%= sale.date %></td>
                            <td><%= sale.orderId.toString().substring(0, 4) %></td>
                            <td><%= sale.paymentMethod %></td>
                            <td><%= sale.gross %></td>
                            <td><%= sale.discount %></td>
                            <td><%= sale.net %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 40px;">No sales data found for this period.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    
    <!-- Using existing simple pagination logic or we can enhance it later if needed -->
    <!-- Ideally, server-side pagination should be implemented, but for now we display all aggregated data -->
    
</div>

<% block('scripts', `
<script>
    // Initialize state
    // Initialize state
    const currentFilter = "${locals.filterType || 'monthly'}";
    const currentStartDate = "${locals.startDate ? new Date(locals.startDate).toISOString().split('T')[0] : ''}";
    const currentEndDate = "${locals.endDate ? new Date(locals.endDate).toISOString().split('T')[0] : ''}";

    // Set initial values
    const periodSelect = document.getElementById('periodFilter');
    periodSelect.value = currentFilter;
    
    if(currentStartDate) document.getElementById('dateFrom').value = currentStartDate;
    if(currentEndDate) document.getElementById('dateTo').value = currentEndDate;

    // Set max date to today for date inputs
    function setMaxDates() {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('dateFrom').setAttribute('max', today);
        document.getElementById('dateTo').setAttribute('max', today);
    }

    // Initialize on page load
    setMaxDates();

    // Show custom date fields if needed
    toggleCustomDate();

    function toggleCustomDate() {
        const period = document.getElementById('periodFilter').value;
        const container = document.getElementById('customDateContainer');
        if (period === 'custom') {
            container.style.display = 'flex';
        } else {
            container.style.display = 'none';
        }
    }

    function applyFilters() {
        const period = document.getElementById('periodFilter').value;
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;

        let url = \`/admin/sales-report?filterType=\${period}\`;
        
        if (period === 'custom') {
            if (!dateFrom || !dateTo) {
                alert('Please select both start and end dates');
                return;
            }
            
            // Validate that dateFrom is not after dateTo
            if (new Date(dateFrom) > new Date(dateTo)) {
                alert('Start date cannot be after end date');
                return;
            }
            
            // Validate that dates are not in the future
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (new Date(dateFrom) > today || new Date(dateTo) > today) {
                alert('Cannot select future dates for sales report');
                return;
            }
            
            url += \`&startDate=\${dateFrom}&endDate=\${dateTo}\`;
        }

        window.location.href = url;
    }

    function downloadReport(format) {
        const period = document.getElementById('periodFilter').value;
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;

        let url = \`/admin/sales-report/download?format=\${format}&filterType=\${period}\`;
        
        if (period === 'custom') {
            if (!dateFrom || !dateTo) {
                alert('Please select both start and end dates');
                return;
            }
            
            // Validate that dateFrom is not after dateTo
            if (new Date(dateFrom) > new Date(dateTo)) {
                alert('Start date cannot be after end date');
                return;
            }
            
            // Validate that dates are not in the future
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (new Date(dateFrom) > today || new Date(dateTo) > today) {
                alert('Cannot select future dates for sales report');
                return;
            }
            
            url += \`&startDate=\${dateFrom}&endDate=\${dateTo}\`;
        }

        window.location.href = url;
    }
</script>
`) %>
