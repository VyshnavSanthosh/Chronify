<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 700;
            color: #ffffff;
            padding-bottom: 2rem;
            text-decoration: underline;
        }
        .table-container {
            overflow-x: auto;
            background-color: #0f1e2e;
            border-radius: 8px;
            border: 1px solid #1a2d4a;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            background-color: #1a3a52;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            font-size: 13px;
            color: #ffffff;
            border-bottom: 1px solid #0f2438;
        }
        td {
            padding: 15px;
            border-bottom: 1px solid #0f2438;
            font-size: 13px;
        }
        tr:hover {
            background-color: #0a1425;
        }
        .product-image {
            width: 50px;
            height: 50px;
            border-radius: 6px;
            object-fit: cover;
            background-color: #1a2d4a;
        }
        .action-buttons {
            display: flex;
            gap: 8px;
        }
        .accept-btn {
            background-color: #22c55e;
            color: #ffffff;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }
        .accept-btn:hover:not(:disabled) {
            background-color: #16a34a;
        }
        .accept-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .reject-btn {
            background-color: #ef4444;
            color: #ffffff;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: background-color 0.3s ease;
        }
        .reject-btn:hover:not(:disabled) {
            background-color: #dc2626;
        }
        .reject-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .pagination {
            display: flex;
            justify-content: end;
            gap: 8px;
            margin-top: 30px;
        }
        .pagination button {
            width: 36px;
            height: 36px;
            border: 1px solid #1a2d4a;
            background-color: transparent;
            color: #b0c4de;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }
        .pagination button:hover:not(:disabled) {
            background-color: #1a2d4a;
            color: #ffffff;
        }
        .pagination button.active {
            background-color: #2d5a8c;
            color: #ffffff;
            border-color: #2d5a8c;
        }
        .pagination button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .pagination-info {
            text-align: center;
            color: #b0c4de;
            font-size: 12px;
            margin-bottom: 15px;
        }
        .swal-dark-popup {
            border: 1px solid #1a2d4a;
        }
        .swal-confirm-btn {
            padding: 10px 24px !important;
            font-weight: 600 !important;
        }
        .swal-cancel-btn {
            padding: 10px 24px !important;
            font-weight: 600 !important;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
`) %>

<!-- Content Area -->
<div class="p-8">
    <div class="breadcrumb text-sm text-gray-400 mb-4">
        <a href="/admin/dashboard" class="hover:text-white">Dashboard</a> > 
        <a href="/admin/products" class="hover:text-white">Products</a> > 
        <span class="text-white">Products Pending List</span>
    </div>
    <div>
        <h1 class="page-title">Product Pending List</h1>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Vendor Name</th>
                    <th>Brand Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
                <% if (products && products.length > 0) { %>
                    <% products.forEach((product) => { %>
                        <tr class="product-row" data-product-id="<%= product._id %>">
                            <td>
                                <% if (product.variants && product.variants.length > 0 && product.variants[0].mainImage) { %>
                                    <img src="<%= product.variants[0].mainImage.url %>" alt="<%= product.name %>" class="product-image">
                                <% } else { %>
                                    <div class="product-image" style="display: flex; align-items: center; justify-content: center; background: #1a2d4a; font-size: 10px; color: #6b7c93;">No Image</div>
                                <% } %>
                            </td>
                            <td><%= product.name %></td>
                            <td><%= product.category ? product.category.categoryName : 'N/A' %></td>
                            <td>
                                <% if (product.variants && product.variants.length > 0) { %>
                                    ₹ <%= product.variants[0].price.toLocaleString() %>
                                <% } else { %>
                                    N/A
                                <% } %>
                            </td>
                            <td>
                                <% if (product.variants && product.variants.length > 0) { %>
                                    <%= product.variants.reduce((sum, v) => sum + v.quantity, 0) %>
                                <% } else { %>
                                    0
                                <% } %>
                            </td>
                            <td><%= product.vendorId ? product.vendorId.brandName : 'N/A' %></td>
                            <td><%= product.brand %></td>
                            <td>
                                <div class="action-buttons">
                                    <button class="accept-btn" onclick="approveProduct('<%= product._id %>')">
                                        <i class="fa-solid fa-check"></i> Accept
                                    </button>
                                    <button class="reject-btn" onclick="rejectProduct('<%= product._id %>')">
                                        <i class="fa-solid fa-times"></i> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" style="text-align: center; padding: 40px; color: #6b7c93;">No pending products found</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination Info -->
    <div class="pagination-info" id="paginationInfo">
        Showing <span id="showingStart">1</span>-<span id="showingEnd">10</span> from <span id="totalCount"><%= locals.totalProducts || 0 %></span>
    </div>

    <!-- Pagination Controls -->
    <div class="pagination" id="paginationContainer">
        <!-- Pagination buttons will be generated by JavaScript -->
    </div>
</div>

<% block('scripts', `
<script>
    // State management
    let currentPage = ${locals.page || 1};
    let totalProducts = ${locals.totalProducts || 0};
    const itemsPerPage = 10;
    let totalPages = Math.ceil(totalProducts / itemsPerPage);

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        updatePaginationUI();
    });

    // Approve product
    async function approveProduct(productId) {
        // Show confirmation dialog
        const result = await Swal.fire({
            title: 'Approve Product?',
            text: 'Are you sure you want to approve this product?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#22c55e',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Approve!',
            cancelButtonText: 'Cancel',
            reverseButtons: true,
            background: '#0f1e2e',
            color: '#ffffff',
            customClass: {
                popup: 'swal-dark-popup',
                confirmButton: 'swal-confirm-btn',
                cancelButton: 'swal-cancel-btn'
            }
        });

        if (!result.isConfirmed) {
            return;
        }

        const row = document.querySelector('tr[data-product-id="' + productId + '"]');
        const buttons = row.querySelectorAll('button');
        
        // Disable buttons
        buttons.forEach(btn => btn.disabled = true);
        buttons[0].innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';

        // Show loading
        Swal.fire({
            title: 'Processing...',
            text: 'Please wait while we approve the product',
            allowOutsideClick: false,
            allowEscapeKey: false,
            allowEnterKey: false,
            showConfirmButton: false,
            background: '#0f1e2e',
            color: '#ffffff',
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch("/admin/products/pendings/" + productId + "/approve", {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const data = await response.json();

            if (response.ok && data.success) {
                // Show success message
                await Swal.fire({
                    title: 'Approved!',
                    text: 'Product has been approved successfully',
                    icon: 'success',
                    confirmButtonColor: '#22c55e',
                    confirmButtonText: 'OK',
                    background: '#0f1e2e',
                    color: '#ffffff',
                    timer: 2000,
                    timerProgressBar: true
                });

                // Remove row with animation
                row.style.transition = 'opacity 0.5s';
                row.style.opacity = '0';
                setTimeout(() => {
                    row.remove();
                    
                    // Update total count
                    totalProducts--;
                    totalPages = Math.ceil(totalProducts / itemsPerPage);
                    updatePaginationUI();

                    // Reload if no products left on current page
                    const remainingRows = document.querySelectorAll('.product-row').length;
                    if (remainingRows === 0 && currentPage > 1) {
                        window.location.href = "/admin/products/pending?page=" + (currentPage - 1);
                    } else if (remainingRows === 0) {
                        location.reload();
                    }
                }, 500);

            } else {
                throw new Error(data.message || 'Failed to approve product');
            }
        } catch (error) {
            console.error('Error approving product:', error);
            
            // Show error message
            Swal.fire({
                title: 'Error!',
                text: error.message || 'Failed to approve product. Please try again.',
                icon: 'error',
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'OK',
                background: '#0f1e2e',
                color: '#ffffff'
            });

            // Re-enable buttons
            buttons.forEach(btn => btn.disabled = false);
            buttons[0].innerHTML = '<i class="fa-solid fa-check"></i> Accept';
        }
    }

    // Reject product
    async function rejectProduct(productId) {
        // Show confirmation dialog
        const result = await Swal.fire({
            title: 'Reject Product?',
            text: 'Are you sure you want to reject this product? This action cannot be undone!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Reject!',
            cancelButtonText: 'Cancel',
            reverseButtons: true,
            background: '#0f1e2e',
            color: '#ffffff',
            customClass: {
                popup: 'swal-dark-popup',
                confirmButton: 'swal-confirm-btn',
                cancelButton: 'swal-cancel-btn'
            }
        });

        if (!result.isConfirmed) {
            return;
        }

        const row = document.querySelector('tr[data-product-id="' + productId + '"]');
        const buttons = row.querySelectorAll('button');
        
        // Disable buttons
        buttons.forEach(btn => btn.disabled = true);
        buttons[1].innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';

        // Show loading
        Swal.fire({
            title: 'Processing...',
            text: 'Please wait while we reject the product',
            allowOutsideClick: false,
            allowEscapeKey: false,
            allowEnterKey: false,
            showConfirmButton: false,
            background: '#0f1e2e',
            color: '#ffffff',
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch("/admin/products/pendings/" + productId + "/reject", {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            });

            const data = await response.json();

            if (response.ok && data.success) {
                // Show success message
                await Swal.fire({
                    title: 'Rejected!',
                    text: 'Product has been rejected successfully',
                    icon: 'success',
                    confirmButtonColor: '#22c55e',
                    confirmButtonText: 'OK',
                    background: '#0f1e2e',
                    color: '#ffffff',
                    timer: 2000,
                    timerProgressBar: true
                });

                // Remove row with animation
                row.style.transition = 'opacity 0.5s';
                row.style.opacity = '0';
                setTimeout(() => {
                    row.remove();
                    
                    // Update total count
                    totalProducts--;
                    totalPages = Math.ceil(totalProducts / itemsPerPage);
                    updatePaginationUI();

                    // Reload if no products left on current page
                    const remainingRows = document.querySelectorAll('.product-row').length;
                    if (remainingRows === 0 && currentPage > 1) {
                        window.location.href = "/admin/products/pending?page=" + (currentPage - 1);
                    } else if (remainingRows === 0) {
                        location.reload();
                    }
                }, 500);

            } else {
                throw new Error(data.message || 'Failed to reject product');
            }
        } catch (error) {
            console.error('Error rejecting product:', error);
            
            // Show error message
            Swal.fire({
                title: 'Error!',
                text: error.message || 'Failed to reject product. Please try again.',
                icon: 'error',
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'OK',
                background: '#0f1e2e',
                color: '#ffffff'
            });

            // Re-enable buttons
            buttons.forEach(btn => btn.disabled = false);
            buttons[1].innerHTML = '<i class="fa-solid fa-times"></i> Reject';
        }
    }

    // Update pagination UI
    function updatePaginationUI() {
        const container = document.getElementById('paginationContainer');
        container.innerHTML = '';

        // Calculate showing range
        const start = totalProducts > 0 ? ((currentPage - 1) * itemsPerPage) + 1 : 0;
        const end = Math.min(currentPage * itemsPerPage, totalProducts);
        
        document.getElementById('showingStart').textContent = start;
        document.getElementById('showingEnd').textContent = end;
        document.getElementById('totalCount').textContent = totalProducts;

        if (totalPages === 0) return;

        // Previous button
        const prevBtn = document.createElement('button');
        prevBtn.innerHTML = '&lt;';
        prevBtn.disabled = currentPage === 1;
        prevBtn.onclick = () => goToPage(currentPage - 1);
        container.appendChild(prevBtn);

        // Page buttons
        const maxVisiblePages = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
        let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

        if (endPage - startPage < maxVisiblePages - 1) {
            startPage = Math.max(1, endPage - maxVisiblePages + 1);
        }

        for (let i = startPage; i <= endPage; i++) {
            const pageBtn = document.createElement('button');
            pageBtn.textContent = i;
            pageBtn.className = i === currentPage ? 'active' : '';
            pageBtn.onclick = () => goToPage(i);
            container.appendChild(pageBtn);
        }

        if (endPage < totalPages) {
            const ellipsis = document.createElement('button');
            ellipsis.textContent = '...';
            ellipsis.disabled = true;
            container.appendChild(ellipsis);
        }

        // Next button
        const nextBtn = document.createElement('button');
        nextBtn.innerHTML = '&gt;';
        nextBtn.disabled = currentPage === totalPages;
        nextBtn.onclick = () => goToPage(currentPage + 1);
        container.appendChild(nextBtn);
    }

    // Go to specific page
    function goToPage(page) {
        if (page < 1 || page > totalPages || page === currentPage) {
            return;
        }
        window.location.href = "/admin/products/pending?page=" + page;
    }
</script>
`) %>