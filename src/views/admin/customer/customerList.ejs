<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .customer-title {
            font-family: 'Playfair Display', serif;
        }
        /* Table scrollbar */
        .table-container::-webkit-scrollbar {
            height: 6px;
        }
        .table-container::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 10px;
        }
    </style>
`) %>

<!-- Content Area -->
<div class="p-8 lg:p-12 space-y-8">
    
    <!-- Breadcrumbs and Title -->
    <div class="space-y-4">
        <h2 class="customer-title text-4xl font-bold tracking-tight">CUSTOMER LIST</h2>
        <nav class="flex text-sm text-gray-400 space-x-2">
            <a href="/admin/dashboard" class="hover:text-white">Dashboard</a>
            <span><i class="fa-solid fa-chevron-right text-[8px] mx-1"></i></span>
            <span class="text-white">Customer List</span>
        </nav>
    </div>

    <!-- Filters Section -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <!-- Search Bar -->
        <div class="relative w-full max-w-md">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
            <input type="text" 
                   id="searchInput"
                   placeholder="Search customer. . ." 
                   class="w-full bg-[#0a1425] border border-gray-800 rounded-lg py-3 pl-12 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
        </div>

        <div class="flex gap-4 w-full md:w-auto">
            <!-- Status Filter -->
            <div class="relative w-full md:w-40">
                <select id="statusFilter" class="w-full appearance-none bg-[#0a1425] border border-gray-800 rounded-lg px-4 py-3 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                    <option value="">All Status</option>
                    <option value="false">Active</option>
                    <option value="true">Blocked</option>
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[10px] pointer-events-none text-gray-400"></i>
            </div>

            <!-- Sort Filter -->
            <div class="relative w-full md:w-40">
                <select id="sortFilter" class="w-full appearance-none bg-[#0a1425] border border-gray-800 rounded-lg px-4 py-3 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                    <option value="">Newest First</option>
                    <option value="az">Name: A-Z</option>
                    <option value="za">Name: Z-A</option>
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[10px] pointer-events-none text-gray-400"></i>
            </div>
        </div>
    </div>

    <!-- Table Container -->
    <div class="table-container overflow-x-auto rounded-xl border border-gray-800">
        <table class="w-full text-left border-collapse min-w-[1000px]">
            <thead>
                <tr class="bg-blue-600 text-white uppercase text-xs font-semibold tracking-wider">
                    <th class="px-6 py-4 border-r border-blue-500/30">Customer Name</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Phone</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Orders</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Balance</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Status</th>
                    <th class="px-6 py-4">Block/Unblock</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800" id="customerTableBody">
                <% customers.forEach((customer) => { %>
                    <tr class="bg-[#050a14] hover:bg-gray-800/50 transition-colors text-sm customer-row" data-customer-id="<%= customer._id %>">
                        <td class="px-6 py-4 border-r border-gray-800">
                            <div class="flex flex-col">
                                <span class="font-medium customer-name"><%= customer.firstName %> <%= customer.lastName %></span>
                                <span class="text-xs text-gray-500"><%= customer.email %></span>
                            </div>
                        </td>
                        <td class="px-6 py-4 border-r border-gray-800 customer-phone"><%= customer.phone || 'N/A' %></td>
                        <td class="px-6 py-4 border-r border-gray-800 customer-orders"><%= customer.orders || 0 %></td>
                        <td class="px-6 py-4 border-r border-gray-800 customer-balance"><%= customer.balance || 0 %></td>
                        <td class="px-6 py-4 border-r border-gray-800 font-bold tracking-tight">
                            <span class="customer-status <%= customer.isBlocked ? 'text-red-500' : 'text-emerald-500' %>">
                                <%= customer.isBlocked ? 'Blocked' : 'Active' %>
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <!-- Block/Unblock Toggle -->
                            <div class="flex items-center">
                                <label class="relative inline-flex items-center cursor-pointer group">
                                    <input type="checkbox" 
                                            class="sr-only peer toggle-block-checkbox" 
                                            data-customer-id="<%= customer._id %>"
                                            <%= customer.isBlocked ? 'checked' : '' %>>
                                    <div class="w-11 h-6 bg-emerald-500 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-500"></div>
                                </label>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-4 gap-4">
        <p class="text-sm text-gray-400">
            Showing <span id="paginationStart">1</span>-<span id="paginationEnd">10</span> from <span id="paginationTotal">0</span>
        </p>
        <div class="flex items-center space-x-2" id="paginationContainer">
            <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors text-xs" id="prevBtn">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="pageButtons"></div>
            <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors text-xs" id="nextBtn">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<% block('scripts', `
<script>
    // Initialize from server data
    var currentPage = ${locals.currentPage || 1};
    var totalCustomers = ${locals.totalCustomers || 0};
    var itemsPerPage = 10;
    var totalPages = Math.ceil(totalCustomers / itemsPerPage);

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        attachToggleListeners();
        attachFilterListeners();
        updatePaginationInfo();
    });

    // Attach toggle listeners
    function attachToggleListeners() {
        document.querySelectorAll('.toggle-block-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', handleToggleBlock);
        });
    }

    // Handle toggle block/unblock
    async function handleToggleBlock(event) {
        const checkbox = event.target;
        const customerId = checkbox.getAttribute('data-customer-id');
        const isBlocked = checkbox.checked;
        const row = checkbox.closest('.customer-row');
        const customerName = row.querySelector('.customer-name').textContent.trim();
        
        // Revert checkbox state immediately, we'll set it after confirmation
        checkbox.checked = !isBlocked;

        const result = await Swal.fire({
            title: isBlocked ? 'Block Customer?' : 'Unblock Customer?',
            text: 'Are you sure you want to ' + (isBlocked ? 'block' : 'unblock') + ' ' + customerName + '?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: isBlocked ? '#ef4444' : '#10b981',
            cancelButtonColor: '#374151',
            confirmButtonText: isBlocked ? 'Yes, Block' : 'Yes, Unblock',
            background: '#0a1425',
            color: '#fff'
        });

        if (!result.isConfirmed) return;

        // Set checkbox back to desired state and disable during request
        checkbox.checked = isBlocked;
        checkbox.disabled = true;

        try {
            const url = "/admin/customers/" + customerId + "/toggle-block";
            
            const response = await fetch(url, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    isBlocked: isBlocked
                })
            });

            const data = await response.json();

            if (data.success) {
                // Update status text and color
                const statusSpan = row.querySelector('.customer-status');
                statusSpan.textContent = isBlocked ? 'Blocked' : 'Active';
                statusSpan.className = "customer-status " + (isBlocked ? 'text-red-500' : 'text-emerald-500');
                
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: data.message,
                    timer: 1500,
                    showConfirmButton: false,
                    background: '#0a1425',
                    color: '#fff'
                });
            } else {
                // Revert toggle on error
                checkbox.checked = !isBlocked;
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: data.message || 'Failed to update status',
                    background: '#0a1425',
                    color: '#fff'
                });
            }
        } catch (error) {
            // Revert toggle on error
            checkbox.checked = !isBlocked;
            Swal.fire({
                icon: 'error',
                title: 'Network Error',
                text: 'Failed to update customer status. Please try again.',
                background: '#0a1425',
                color: '#fff'
            });
        } finally {
            // Re-enable checkbox
            checkbox.disabled = false;
        }
    }

    // Attach filter listeners
    function attachFilterListeners() {
        document.getElementById('searchInput').addEventListener('keyup', debounce(applyFilters, 500));
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('sortFilter').addEventListener('change', applyFilters);
    }

    // Debounce function for search
    function debounce(func, delay) {
        var timeoutId;
        return function(...args) {
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => func.apply(this, args), delay);
        };
    }

    // Apply filters and reload data
    async function applyFilters() {
        const search = document.getElementById('searchInput').value;
        const status = document.getElementById('statusFilter').value;
        const sort = document.getElementById('sortFilter').value;
        
        currentPage = 1;
        
        try {
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            if (status !== '') params.append('status', status);
            if (sort) params.append('sort', sort);
            params.append('page', currentPage);

            const response = await fetch("/admin/customers?" + params.toString());
            const html = await response.text();
            
            // Parse the response and extract the table body
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newTableBody = doc.getElementById('customerTableBody');
            
            document.getElementById('customerTableBody').innerHTML = newTableBody.innerHTML;
            
            // Extract totalCustomers from the response
            const scriptMatch = html.match(/var totalCustomers = (\\d+);/);
            if (scriptMatch) {
                totalCustomers = parseInt(scriptMatch[1]);
                totalPages = Math.ceil(totalCustomers / itemsPerPage);
            }
            
            attachToggleListeners();
            updatePaginationInfo();
        } catch (error) {
            console.error('Error applying filters:', error);
            alert('Failed to apply filters. Please try again.');
        }
    }

    // Update pagination
    function updatePaginationInfo() {
        const pageButtons = document.getElementById('pageButtons');
        
        // Calculate start and end
        const start = totalCustomers > 0 ? ((currentPage - 1) * itemsPerPage) + 1 : 0;
        const end = Math.min(currentPage * itemsPerPage, totalCustomers);
        
        document.getElementById('paginationStart').textContent = start;
        document.getElementById('paginationEnd').textContent = end;
        document.getElementById('paginationTotal').textContent = totalCustomers;
        
        // Generate page buttons
        pageButtons.innerHTML = '';
        
        if (totalPages === 0) {
            return; // Don't show pagination if no results
        }
        
        const maxVisiblePages = 5;
        var startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
        var endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
        
        if (endPage - startPage < maxVisiblePages - 1) {
            startPage = Math.max(1, endPage - maxVisiblePages + 1);
        }
        
        for (var i = startPage; i <= endPage; i++) {
            const btn = document.createElement('button');
            const pageNum = i;
            btn.className = "w-8 h-8 flex items-center justify-center rounded-lg font-bold text-xs transition-colors " + (pageNum === currentPage ? 'bg-blue-600 text-white' : 'bg-white text-black hover:bg-gray-200');
            btn.textContent = pageNum;
            btn.addEventListener('click', function() {
                goToPage(pageNum);
            });
            pageButtons.appendChild(btn);
        }
        
        if (endPage < totalPages) {
            const span = document.createElement('span');
            span.className = 'px-2 text-gray-500';
            span.textContent = '...';
            pageButtons.appendChild(span);
        }

        // Update prev/next button state
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage >= totalPages;
        
        if (prevBtn.disabled) {
            prevBtn.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            prevBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
        
        if (nextBtn.disabled) {
            nextBtn.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    }

    // Go to page
    function goToPage(page) {
        if (page === currentPage || page < 1 || page > totalPages) {
            return;
        }
        
        const search = document.getElementById('searchInput').value;
        const status = document.getElementById('statusFilter').value;
        const sort = document.getElementById('sortFilter').value;
        
        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (status !== '') params.append('status', status);
        if (sort) params.append('sort', sort);
        params.append('page', page);

        window.location.href = "/admin/customers?" + params.toString();
    }

    // Previous button
    document.getElementById('prevBtn').addEventListener('click', function() {
        if (currentPage > 1) {
            goToPage(currentPage - 1);
        }
    });

    // Next button
    document.getElementById('nextBtn').addEventListener('click', function() {
        if (currentPage < totalPages) {
            goToPage(currentPage + 1);
        }
    });
</script>
`) %>