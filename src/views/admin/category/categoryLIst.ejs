<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .category-title {
            font-family: 'Playfair Display', serif;
        }
        /* Table scrollbar */
        .table-container::-webkit-scrollbar {
            height: 6px;
        }
        .table-container::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 10px;
        }
        /* Custom List/Unlist Toggle styling */
        .toggle-btn {
            position: relative;
            display: inline-flex;
            align-items: center;
            width: 76px;
            height: 32px;
            border-radius: 9999px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
        }
        .toggle-btn.listed {
            background-color: #65a30d;
            justify-content: flex-start;
            padding-left: 8px;
        }
        .toggle-btn.unlisted {
            background-color: #ef4444;
            justify-content: flex-start;
            padding-left: 12px;
        }
        .toggle-circle {
            position: absolute;
            width: 24px;
            height: 24px;
            background-color: white;
            border-radius: 50%;
            top: 4px;
            transition: all 0.3s;
            right: 4px;
        }
        /* Offer badge styling */
        .offer-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .offer-badge.percentage {
            background-color: #10b981;
            color: white;
        }
        .offer-badge.flat {
            background-color: #3b82f6;
            color: white;
        }
        .offer-badge.none {
            background-color: #6b7280;
            color: white;
        }
    </style>
`) %>

<!-- Content Area -->
<div class="p-8 lg:p-12 space-y-8 relative">
    
    <!-- Add Category Button (Absolute top right of container) -->
    <div class="absolute right-8 lg:right-12 top-8 lg:top-12">
        <a href="/admin/category/add" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-md transition-all inline-block shadow-lg">
            Add Category
        </a>
    </div>

    <!-- Page Title and Breadcrumbs -->
    <div class="space-y-4 pt-4">
        <h2 class="category-title text-4xl font-bold tracking-tight uppercase">CATEGORY LIST</h2>
        <nav class="flex text-sm text-gray-400 space-x-2">
            <a href="/admin/dashboard" class="hover:text-white capitalize">Dashboard</a>
            <span><i class="fa-solid fa-chevron-right text-[8px] mx-1"></i></span>
            <span class="text-white capitalize">Category List</span>
        </nav>
    </div>

    <!-- Filters Section -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between pt-4">
        <!-- Search Bar -->
        <div class="relative w-full max-w-md">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
            <input type="text" 
                   id="searchInput"
                   placeholder="Search Category. . ." 
                   class="w-full bg-[#0a1425] border border-gray-800 rounded-lg py-3 pl-12 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
        </div>

        <div class="flex gap-4 w-full md:w-auto">
            <!-- Status Filter -->
            <div class="relative w-full md:w-40">
                <select id="statusFilter" class="w-full appearance-none bg-[#0a1425] border border-gray-800 rounded-lg px-4 py-3 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                    <option value="">All Status</option>
                    <option value="true">Listed</option>
                    <option value="false">Unlisted</option>
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[10px] pointer-events-none text-gray-400"></i>
            </div>

            <!-- Sort Filter -->
            <div class="relative w-full md:w-40">
                <select id="sortFilter" class="w-full appearance-none bg-[#0a1425] border border-gray-800 rounded-lg px-4 py-3 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                    <option value="">Newest First</option>
                    <option value="az">Name: A-Z</option>
                    <option value="za">Name: Z-A</option>
                </select>
                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[10px] pointer-events-none text-gray-400"></i>
            </div>
        </div>
    </div>

    <!-- Table Container -->
    <div class="table-container overflow-x-auto rounded-xl border border-gray-800">
        <table class="w-full text-left border-collapse min-w-[1200px]">
            <thead>
                <tr class="bg-[#4169a1] text-white text-xs font-semibold tracking-wider">
                    <th class="px-6 py-4 border-r border-white/10 text-center w-20 uppercase">SNO</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase">Category Name</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase">Description</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase text-center">Offer Type</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase text-center">Offer</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase">Added</th>
                    <th class="px-6 py-4 border-r border-white/10 uppercase text-center">List / Unlist</th>
                    <th class="px-6 py-4 uppercase text-center">Edit</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800" id="categoryTableBody">
                <% categories.forEach((category, index) => { %>
                    <tr class="bg-[#050a14] hover:bg-gray-800/50 transition-colors text-sm category-row" data-category-id="<%= category._id %>">
                        <td class="px-6 py-8 border-r border-gray-800 text-center font-bold">
                            <%= ((locals.currentPage || 1) - 1) * 10 + index + 1 %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800 font-medium category-name">
                            <%= category.categoryName %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800 font-medium text-gray-300">
                            <%= category.description || 'N/A' %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800 text-center">
                            <% if (category.discountType) { %>
                                <span class="offer-badge <%= category.offerType === 'percentage' ? 'percentage' : 'flat' %>">
                                    <%= category.discountType === 'percentage' ? 'Percentage' : 'Flat' %>
                                </span>
                            <% } else { %>
                                <span class="offer-badge none">No Offer</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800 text-center font-bold text-emerald-400">
                            <% if (category.discountValue && category.discountValue > 0) { %>
                                <%= category.discountType === 'percentage' ? category.discountValue + '%' : '₹' + category.discountValue %>
                            <% } else { %>
                                <span class="text-gray-500">-</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800 font-medium text-gray-300">
                            <%= new Date(category.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                        </td>
                        <td class="px-6 py-8 border-r border-gray-800">
                            <div class="flex justify-center">
                                <div class="toggle-btn <%= category.isListed ? 'listed' : 'unlisted' %> toggle-list-btn"
                                     data-category-id="<%= category._id %>"
                                     data-is-listed="<%= category.isListed %>">
                                    <span><%= category.isListed ? 'UNLIST' : 'LIST' %></span>
                                    <div class="toggle-circle"></div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-8">
                            <div class="flex justify-center">
                                <a href="/admin/category/edit/<%= category._id %>" 
                                   class="w-10 h-10 flex items-center justify-center rounded-lg bg-gray-800/50 border border-gray-700 hover:bg-gray-700 transition-all text-gray-400 hover:text-white">
                                    <i class="fa-regular fa-pen-to-square"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-4 gap-4">
        <p class="text-sm text-gray-400">
            Showing <span id="paginationStart">1</span>-<span id="paginationEnd">10</span> from <span id="paginationTotal">0</span>
        </p>
        <div class="flex items-center space-x-2" id="paginationContainer">
            <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors text-xs" id="prevBtn">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="pageButtons"></div>
            <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors text-xs" id="nextBtn">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<% block('scripts', `
<script>
    // Initialize from server data
    var currentPage = ${locals.currentPage || 1};
    var totalCategories = ${locals.totalCategories || 0};
    var itemsPerPage = 10;
    var totalPages = Math.ceil(totalCategories / itemsPerPage);

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Page loaded - currentPage:', currentPage, 'totalCategories:', totalCategories, 'totalPages:', totalPages);
        attachToggleListeners();
        attachFilterListeners();
        updatePaginationInfo();
    });

    // Attach toggle listeners
    function attachToggleListeners() {
        document.querySelectorAll('.toggle-list-btn').forEach(toggle => {
            toggle.addEventListener('click', handleToggleListing);
        });
    }

    // Handle toggle list/unlist
    async function handleToggleListing(event) {
        const toggle = event.currentTarget;
        const categoryId = toggle.getAttribute('data-category-id');
        const currentStatus = toggle.getAttribute('data-is-listed') === 'true';
        const newStatus = !currentStatus;
        const categoryName = toggle.closest('.category-row').querySelector('.category-name').textContent.trim();
        
        const result = await Swal.fire({
            title: newStatus ? 'List Category?' : 'Unlist Category?',
            text: 'Are you sure you want to ' + (newStatus ? 'list' : 'unlist') + ' ' + categoryName + '?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: newStatus ? '#10b981' : '#ef4444',
            cancelButtonColor: '#374151',
            confirmButtonText: newStatus ? 'Yes, List' : 'Yes, Unlist',
            background: '#0a1425',
            color: '#fff'
        });

        if (!result.isConfirmed) return;

        // Disable toggle during request
        toggle.style.pointerEvents = 'none';
        toggle.style.opacity = '0.6';

        try {
            const url = "/admin/category/" + categoryId + "/toggle-listing";
            
            const response = await fetch(url, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    isListed: newStatus
                })
            });

            const data = await response.json();

            if (data.success) {
                // Update toggle appearance
                toggle.setAttribute('data-is-listed', newStatus);
                toggle.className = "toggle-btn " + (newStatus ? 'listed' : 'unlisted') + " toggle-list-btn";
                toggle.querySelector('span').textContent = newStatus ? 'UNLIST' : 'LIST';
                
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: data.message,
                    timer: 1500,
                    showConfirmButton: false,
                    background: '#0a1425',
                    color: '#fff'
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: data.message || 'Failed to update status',
                    background: '#0a1425',
                    color: '#fff'
                });
            }
        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Network Error',
                text: 'Failed to update category status. Please try again.',
                background: '#0a1425',
                color: '#fff'
            });
        } finally {
            // Re-enable toggle
            toggle.style.pointerEvents = '';
            toggle.style.opacity = '';
        }
    }

    // Attach filter listeners
    function attachFilterListeners() {
        document.getElementById('searchInput').addEventListener('keyup', debounce(applyFilters, 500));
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('sortFilter').addEventListener('change', applyFilters);
    }

    // Debounce function for search
    function debounce(func, delay) {
        var timeoutId;
        return function(...args) {
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => func.apply(this, args), delay);
        };
    }

    // Apply filters and reload data
    async function applyFilters() {
        const search = document.getElementById('searchInput').value;
        const status = document.getElementById('statusFilter').value;
        const sort = document.getElementById('sortFilter').value;
        
        currentPage = 1;
        
        try {
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            if (status !== '') params.append('status', status);
            if (sort) params.append('sort', sort);
            params.append('page', currentPage);

            const response = await fetch("/admin/category?" + params.toString());
            const html = await response.text();
            
            // Parse the response and extract the table body
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newTableBody = doc.getElementById('categoryTableBody');
            
            document.getElementById('categoryTableBody').innerHTML = newTableBody.innerHTML;
            
            // Extract totalCategories from the response
            const scriptMatch = html.match(/var totalCategories = (\\d+);/);
            if (scriptMatch) {
                totalCategories = parseInt(scriptMatch[1]);
                totalPages = Math.ceil(totalCategories / itemsPerPage);
            }
            
            attachToggleListeners();
            updatePaginationInfo();
        } catch (error) {
            console.error('Error applying filters:', error);
            alert('Failed to apply filters. Please try again.');
        }
    }

    // Update pagination
    function updatePaginationInfo() {
        const pageButtons = document.getElementById('pageButtons');
        
        // Calculate start and end
        const start = totalCategories > 0 ? ((currentPage - 1) * itemsPerPage) + 1 : 0;
        const end = Math.min(currentPage * itemsPerPage, totalCategories);
        
        document.getElementById('paginationStart').textContent = start;
        document.getElementById('paginationEnd').textContent = end;
        document.getElementById('paginationTotal').textContent = totalCategories;
        
        // Generate page buttons
        pageButtons.innerHTML = '';
        
        if (totalPages === 0) {
            return; // Don't show pagination if no results
        }
        
        const maxVisiblePages = 5;
        var startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
        var endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
        
        if (endPage - startPage < maxVisiblePages - 1) {
            startPage = Math.max(1, endPage - maxVisiblePages + 1);
        }
        
        for (var i = startPage; i <= endPage; i++) {
            const btn = document.createElement('button');
            const pageNum = i;
            btn.className = "w-8 h-8 flex items-center justify-center rounded-lg font-bold text-xs transition-colors " + (pageNum === currentPage ? 'bg-blue-600 text-white' : 'bg-white text-black hover:bg-gray-200');
            btn.textContent = pageNum;
            btn.addEventListener('click', function() {
                goToPage(pageNum);
            });
            pageButtons.appendChild(btn);
        }
        
        if (endPage < totalPages) {
            const span = document.createElement('span');
            span.className = 'px-2 text-gray-500';
            span.textContent = '...';
            pageButtons.appendChild(span);
        }

        // Update prev/next button state
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage >= totalPages;
        
        if (prevBtn.disabled) {
            prevBtn.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            prevBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
        
        if (nextBtn.disabled) {
            nextBtn.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    }

    // Go to page
    function goToPage(page) {
        if (page === currentPage || page < 1 || page > totalPages) {
            return;
        }
        
        const search = document.getElementById('searchInput').value;
        const status = document.getElementById('statusFilter').value;
        const sort = document.getElementById('sortFilter').value;
        
        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (status !== '') params.append('status', status);
        if (sort) params.append('sort', sort);
        params.append('page', page);

        window.location.href = "/admin/category?" + params.toString();
    }

    // Previous button
    document.getElementById('prevBtn').addEventListener('click', function() {
        if (currentPage > 1) {
            goToPage(currentPage - 1);
        }
    });

    // Next button
    document.getElementById('nextBtn').addEventListener('click', function() {
        if (currentPage < totalPages) {
            goToPage(currentPage + 1);
        }
    });
</script>
`) %>