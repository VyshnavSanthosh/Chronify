<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .custom-dark-card {
            background-color: #0a1425;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        input::placeholder, textarea::placeholder {
            color: #9ca3af;
            font-size: 0.875rem;
        }
        .error-message {
            color: #ef4444;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
`) %>

<!-- Content Area -->
<div class="p-8 lg:p-16 flex flex-col items-center">
    
    <div class="w-full max-w-5xl space-y-12">
        <h2 class="text-3xl font-bold tracking-wider text-white uppercase italic">EDIT CATEGORY</h2>

        <!-- General Error Message -->
        <% if (locals.errorMessage) { %>
            <div class="bg-red-500/20 border border-red-500 text-red-400 px-6 py-4 rounded-lg">
                <div class="flex items-center space-x-2">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= errorMessage %></span>
                </div>
            </div>
        <% } %>

        <form id="categoryForm" action="/admin/category/edit/<%= category._id %>" method="POST" class="space-y-8">
            
            <!-- Category Name -->
            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400">Category Name</label>
                <input type="text" name="categoryName" placeholder="Type category name here. . ." 
                    value="<%= category?.categoryName || '' %>"
                    class="w-full bg-[#f3f4f6] text-black px-6 py-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg shadow-sm <%= locals.errors?.categoryName ? 'ring-2 ring-red-500' : '' %>">
                <% if (locals.errors?.categoryName) { %>
                    <div class="error-message"><%= errors.categoryName %></div>
                <% } %>
            </div>

            <!-- Description -->
            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400">Description</label>
                <textarea name="description" rows="10" placeholder="Type category description here. . ." 
                    class="w-full bg-[#f3f4f6] text-black px-6 py-6 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg shadow-sm resize-none <%= locals.errors?.description ? 'ring-2 ring-red-500' : '' %>"><%= category?.description || '' %></textarea>
                <% if (locals.errors?.description) { %>
                    <div class="error-message"><%= errors.description %></div>
                <% } %>
            </div>

            <!-- Discount Type and Value Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex flex-col space-y-2">
                    <label class="text-sm font-medium text-gray-400">Discount Type</label>
                    <select name="discountType" 
                        class="bg-[#f3f4f6] text-black px-6 py-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg shadow-sm <%= locals.errors?.discountType ? 'ring-2 ring-red-500' : '' %>">
                        <option value="">Select discount type</option>
                        <option value="percentage" <%= category?.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                        <option value="flat" <%= category?.discountType === 'flat' ? 'selected' : '' %>>Flat Amount (Rs.)</option>
                    </select>
                    <% if (locals.errors?.discountType) { %>
                        <div class="error-message"><%= errors.discountType %></div>
                    <% } %>
                </div>

                <div class="flex flex-col space-y-2">
                    <label class="text-sm font-medium text-gray-400">Discount Value</label>
                    <input type="number" name="discountValue" placeholder="Ex: 10 or 100" step="0.01"
                        value="<%= category?.discountValue || '' %>"
                        class="bg-[#f3f4f6] text-black px-6 py-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg shadow-sm <%= locals.errors?.discountValue ? 'ring-2 ring-red-500' : '' %>">
                    <% if (locals.errors?.discountValue) { %>
                        <div class="error-message"><%= errors.discountValue %></div>
                    <% } %>
                </div>
            </div>

            <!-- Max Redeemable -->
            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400">Max Redeemable Amount <span id="maxRedeemableRequired" class="text-red-500" style="display: none;">*</span> <span class="text-gray-500">(Optional for Discount type Percentage )</span></label>
                <input type="number" name="maxRedeemable" placeholder="Ex: 500 (leave empty if no limit)" step="0.01"
                    value="<%= category?.maxRedeemable || '' %>"
                    class="w-full bg-[#f3f4f6] text-black px-6 py-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg shadow-sm <%= locals.errors?.maxRedeemable ? 'ring-2 ring-red-500' : '' %>"
                    id="maxRedeemableInput">
                <% if (locals.errors?.maxRedeemable) { %>
                    <div class="error-message"><%= errors.maxRedeemable %></div>
                <% } %>
                <div class="error-message" id="maxRedeemableError"></div>
                
                <!-- Info Note -->
                <div class="bg-blue-500/10 border border-blue-500/30 text-blue-300 px-4 py-3 rounded-lg text-sm">
                    <div class="flex space-x-2">
                        <i class="fa-solid fa-info-circle mt-0.5 flex-shrink-0"></i>
                        <div>
                            <p class="font-semibold mb-2">Important for Fixed Discounts:</p>
                            <p class="leading-relaxed">
                                If the discount value is higher than the allowed percentage of the product price, only the maximum redeemable percentage will be applied.
                            </p>
                            <p class="mt-2 text-blue-400/80">
                                <span class="font-semibold">Example:</span> A ₹5000 fixed discount on a ₹9000 product with a 30% cap will apply only ₹2700.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-8 flex justify-center">
                <button type="submit" class="bg-[#1d63c1] hover:bg-blue-700 text-white font-bold py-4 px-16 rounded-xl text-xl shadow-lg transition-all duration-300 transform hover:scale-105 active:scale-95">
                    Save Changes
                </button>
            </div>

        </form>
    </div>

</div>

<% block('scripts', `
<script>
    const form = document.getElementById('categoryForm');
    const discountTypeSelect = document.querySelector('select[name="discountType"]');
    const maxRedeemableInput = document.getElementById('maxRedeemableInput');
    const maxRedeemableRequiredLabel = document.getElementById('maxRedeemableRequired');
    const maxRedeemableErrorDiv = document.getElementById('maxRedeemableError');

    // Function to validate and update UI based on discount type
    function updateMaxRedeemableRequirement() {
        const isFixedDiscount = discountTypeSelect.value === 'flat';
        
        if (isFixedDiscount) {
            maxRedeemableInput.required = true;
            maxRedeemableRequiredLabel.style.display = 'inline';
        } else {
            maxRedeemableInput.required = false;
            maxRedeemableRequiredLabel.style.display = 'none';
            maxRedeemableErrorDiv.textContent = ''; 
        }
    }

    discountTypeSelect.addEventListener('change', updateMaxRedeemableRequirement);
    updateMaxRedeemableRequirement();

    function clearErrors() {
        document.querySelectorAll('.error-message').forEach(el => el.textContent = '');
        document.querySelectorAll('input, select, textarea').forEach(el => el.classList.remove('ring-2', 'ring-red-500'));
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearErrors();

        const isFixedDiscount = discountTypeSelect.value === 'flat';
        const maxRedeemableValue = maxRedeemableInput.value.trim();

        if (isFixedDiscount && !maxRedeemableValue) {
            maxRedeemableErrorDiv.textContent = 'Max redeemable amount is required for fixed discounts';
            maxRedeemableInput.classList.add('ring-2', 'ring-red-500');
            maxRedeemableInput.focus();
            return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok && result.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: result.message,
                    background: '#0a1425',
                    color: '#fff',
                    confirmButtonColor: '#1d63c1'
                }).then(() => {
                    window.location.href = result.redirectUrl || '/admin/category';
                });
            } else {
                if (result.errors) {
                    Object.keys(result.errors).forEach(key => {
                        const input = document.querySelector(`[name="${key}"]`);
                        if (input) {
                            input.classList.add('ring-2', 'ring-red-500');
                            const errorDiv = input.parentElement.querySelector('.error-message') || 
                                           document.getElementById(`${key}Error`);
                            if (errorDiv) {
                                errorDiv.textContent = result.errors[key];
                            }
                        }
                    });
                }

                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: result.message || 'Something went wrong!',
                    background: '#0a1425',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            }
        } catch (error) {
            console.error('Error updating category:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to update category. Please try again.',
                background: '#0a1425',
                color: '#fff',
                confirmButtonColor: '#ef4444'
            });
        }
    });
</script>
`) %>