<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        .custom-dark-card {
            background-color: #0a192f;
        }
    </style>
`) %>

<!-- Content Area -->
<div class="flex-1 p-12 flex justify-center items-center">
    
    <!-- Admin Profile Card -->
    <div class="w-full max-w-4xl custom-dark-card rounded-3xl p-12 shadow-2xl">
        <div class="flex flex-col items-center text-center mb-10">
            <h2 class="text-sm font-medium tracking-[0.2em] mb-4 uppercase">
                Welcome <br> 
                <span class="text-xs opacity-70">Admin</span>
            </h2>
            
            <!-- Admin Icon -->
            <div class="mb-4">
                <img src="/assets/userIcon.png" alt="Admin Profile" class="w-20 h-20 rounded-xl bg-white p-1">
            </div>
            
            <!-- Admin Name -->
            <a href="#" class="text-lg font-semibold underline decoration-1 underline-offset-4">
                <%= user.firstName %> <%= user.lastName || '' %>
            </a>
        </div>

        <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- First Name -->
                <div>  
                    <label class="block text-sm font-medium text-gray-300 mb-2">First Name</label>
                    <input type="text" value="<%= user.firstName || '' %>" 
                            class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500" readonly>
                </div>
                <!-- Last Name -->
                <div>  
                    <label class="block text-sm font-medium text-gray-300 mb-2">Last Name</label>
                    <input type="text" value="<%= user.lastName || '' %>" 
                            class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500" readonly>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Email -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                    <input type="email" placeholder="Your email" value="<%= user.email || '' %>"
                            class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500" readonly>
                </div>
                <!-- Phone Number -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Phone Number</label>
                    <input type="text" placeholder="Phone Number" value="<%= user.phone || '' %>"
                           class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500" readonly>
                </div>
            </div>
        </form>
    </div>
</div>
