<% layout('admin/layout/adminLayout') %>

<% block('styles', `
    <style>
        /* Custom scrollbar for table container */
        .table-container::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .table-container::-webkit-scrollbar-track {
            background: #0a1425;
        }
        .table-container::-webkit-scrollbar-thumb {
            background: #1f2937;
            border-radius: 3px;
        }
        .table-container::-webkit-scrollbar-thumb:hover {
            background: #374151;
        }
    </style>
`) %>

<!-- Content Area -->
<div class="p-8 lg:p-12 space-y-8">
    
    <!-- Title and Breadcrumbs -->
    <div class="space-y-4">
        <h2 class="text-4xl font-bold tracking-tight" style="font-family: 'Playfair Display', serif;">ORDER LIST</h2>
        <nav class="flex text-sm text-gray-400 space-x-2">
            <a href="/admin/dashboard" class="hover:text-white capitalize">Dashboard</a>
            <span><i class="fa-solid fa-chevron-right text-[8px] mx-1"></i></span>
            <span class="text-white capitalize">Order List</span>
        </nav>
    </div>

    <!-- Filters Section -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <!-- Search Bar -->
        <div class="relative w-full max-w-md">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
            <input type="text" 
                   id="searchInput"
                   placeholder="Search by Order ID..." 
                   class="w-full bg-[#0a1425] border border-gray-800 rounded-lg py-3 pl-12 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
        </div>

        <!-- Status Filter -->
        <div class="relative w-full md:w-64">
            <select id="statusFilter" 
                    onchange="filterStatus(this.value)"
                    class="w-full bg-[#0a1425] border border-gray-800 rounded-lg py-3 px-4 text-sm text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 appearance-none cursor-pointer transition-all">
                <option value="">All Statuses</option>
                <% ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled', 'returned', 'return_requested'].forEach(s => { %>
                    <option value="<%= s %>" <%= (typeof status !== 'undefined' && status === s) ? 'selected' : '' %>>
                        <%= s.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %>
                    </option>
                <% }) %>
            </select>
            <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
        </div>
    </div>

    <!-- Table Container -->
    <div class="table-container overflow-x-auto rounded-xl border border-gray-800">
        <table class="w-full text-left border-collapse min-w-[1000px]">
            <thead>
                <tr class="bg-blue-600 text-white uppercase text-xs font-semibold tracking-wider">
                    <th class="px-6 py-4 border-r border-blue-500/30">Order ID</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Date Logged</th>
                    <th class="px-6 py-4 border-r border-blue-500/30">Status</th>
                    <th class="px-6 py-4 border-r border-blue-500/30 text-center">Items</th>
                    <th class="px-6 py-4 border-r border-blue-500/30 text-right">Total</th>
                    <th class="px-6 py-4 text-center">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800" id="orderTableBody">
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { 
                        // Format date from MongoDB timestamp
                        const orderDate = new Date(order.createdAt);
                        const formattedDate = orderDate.toLocaleDateString('en-US', { 
                            year: 'numeric', 
                            month: 'short', 
                            day: 'numeric' 
                        });
                        
                        // Get current status from statusHistory
                        const currentStatus = order.statusHistory && order.statusHistory.length > 0 
                            ? order.statusHistory[order.statusHistory.length - 1].status 
                            : 'pending';
                        
                        // Format Order ID (show last 8 characters of MongoDB _id)
                        const orderId = order._id.toString().slice(-6).toUpperCase();
                        
                        // Count items
                        const itemCount = order.items ? order.items.length : 0;
                        
                        // Format total with 1 decimal place
                        const formattedTotal = order.total ? order.total.toFixed(1) : '0.0';
                    %>
                        <tr class="bg-[#050a14] hover:bg-gray-800/50 transition-colors text-sm group" data-order-id="<%= orderId %>">
                            <td class="px-6 py-4 border-r border-gray-800 font-medium text-blue-400 group-hover:text-blue-300">
                                #<%= orderId %>
                            </td>
                            <td class="px-6 py-4 border-r border-gray-800 text-gray-300">
                                <%= formattedDate %>
                            </td>
                            <td class="px-6 py-4 border-r border-gray-800">
                                <% 
                                    let statusColor = "bg-yellow-500/10 text-yellow-500 border-yellow-500/20";
                                    let icon = "fa-clock";
                                    let displayStatus = currentStatus;
                                    
                                    if(currentStatus === 'delivered') {
                                        statusColor = "bg-green-500/10 text-green-500 border-green-500/20";
                                        icon = "fa-check-circle";
                                    } else if(currentStatus === 'cancelled') {
                                        statusColor = "bg-red-500/10 text-red-500 border-red-500/20";
                                        icon = "fa-circle-xmark";
                                    } else if(currentStatus === 'shipped' || currentStatus === 'out_for_delivery') {
                                        statusColor = "bg-blue-500/10 text-blue-500 border-blue-500/20";
                                        icon = "fa-truck";
                                    } else if(currentStatus === 'processing') {
                                        statusColor = "bg-purple-500/10 text-purple-500 border-purple-500/20";
                                        icon = "fa-spinner";
                                    }
                                    
                                    // Format display status (replace underscores, capitalize)
                                    displayStatus = currentStatus.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
                                %>
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border <%= statusColor %>">
                                    <i class="fa-solid <%= icon %>"></i>
                                    <%= displayStatus %>
                                </span>
                            </td>
                            <td class="px-6 py-4 border-r border-gray-800 text-center">
                                <span class="bg-gray-800 text-gray-300 px-2.5 py-1 rounded-md text-xs font-semibold">
                                    <%= itemCount %>
                                </span>
                            </td>
                            <td class="px-6 py-4 border-r border-gray-800 text-right font-semibold text-white">
                                ₹<%= formattedTotal %>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <button class="text-gray-400 hover:text-white hover:bg-gray-700 p-2 rounded-lg transition-colors" 
                                        title="View Details"
                                        onclick="viewOrderDetails('<%= order._id %>')">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                            <div class="flex flex-col items-center gap-3">
                                <div class="h-16 w-16 bg-gray-800/50 rounded-full flex items-center justify-center text-2xl mb-2">
                                    <i class="fa-solid fa-box-open text-gray-600"></i>
                                </div>
                                <p class="text-lg font-medium">No orders found</p>
                                <p class="text-sm">When customers purchase your products, they will appear here.</p>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-4 gap-4">
        <p class="text-sm text-gray-400">
            Showing <span id="orderCount"><%= orders.length %></span> order<%= orders.length !== 1 ? 's' : '' %> of <%= totalOrders %>
        </p>
        <div class="flex items-center space-x-2">
            <button onclick="goToPage(<%= currentPage - 1 %>)" 
                    <%= currentPage === 1 ? 'disabled' : '' %>
                    class="px-3 py-1.5 rounded-lg bg-gray-800 text-gray-400 hover:text-white disabled:opacity-50 text-xs transition-all">
                Previous
            </button>
            
            <% for(let i = 1; i <= totalPages; i++) { %>
                <button onclick="goToPage(<%= i %>)"
                        class="px-3 py-1.5 rounded-lg <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white' %> text-xs transition-all">
                    <%= i %>
                </button>
            <% } %>

            <button onclick="goToPage(<%= currentPage + 1 %>)"
                    <%= currentPage === totalPages ? 'disabled' : '' %>
                    class="px-3 py-1.5 rounded-lg bg-gray-800 text-gray-400 hover:text-white disabled:opacity-50 text-xs transition-all">
                Next
            </button>
        </div>
    </div>
</div>

<% block('scripts', `
<script>
    function goToPage(page) {
        const url = new URL(window.location.href);
        url.searchParams.set('page', page);
        window.location.href = url.toString();
    }

    function filterStatus(status) {
        const url = new URL(window.location.href);
        if (status) {
            url.searchParams.set('status', status);
        } else {
            url.searchParams.delete('status');
        }
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    }
    // Search functionality
    document.getElementById('searchInput').addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#orderTableBody tr');
        let visibleCount = 0;
        
        rows.forEach(row => {
            const orderId = row.getAttribute('data-order-id');
            if (!orderId) return; // Skip empty state row
            
            if (orderId.toLowerCase().includes(searchTerm)) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        // Update count
        document.getElementById('orderCount').textContent = visibleCount;
    });
    
    // View order details function
    function viewOrderDetails(orderId) {
        // Redirect to order detail page
        window.location.href = '/admin/orders/' + orderId;
    }
</script>
`) %>