<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chronify - Luxury Watches</title>
    <link rel="icon" type="image/png" href="/assets/letter-c.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('user/partials/userStyles') %>
    <style>
        /* Hero Section */
        .hero-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 80px 48px;
            min-height: 80vh;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
            overflow: hidden;
        }

        .hero-content {
            flex: 1;
            max-width: 600px;
            z-index: 2;
        }

        .hero-tagline {
            font-size: 48px;
            font-weight: 300;
            line-height: 1.2;
            margin-bottom: 24px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .hero-image-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .hero-image-container img {
            max-width: 100%;
            height: auto;
            z-index: 2;
            filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));
            transition: transform 0.3s ease;
        }

        .moon-bg {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 1;
        }

        /* Explore More Section */
        .explore-section {
            padding: 80px 48px;
            background: #000;
        }

        .section-title {
            font-size: 24px;
            font-weight: 300;
            letter-spacing: 4px;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 60px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 32px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .product-card {
            background: linear-gradient(135deg, #1a2855 0%, #0f1a35 100%);
            border: 1px solid #2a3f66;
            border-radius: 12px;
            padding: 24px;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .product-card:hover {
            transform: translateY(-10px);
            border-color: #3b82f6;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .product-image {
            width: 100%;
            aspect-ratio: 1;
            background: #000;
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover .product-image img {
            transform: scale(1.1);
        }

        .product-name {
            font-size: 16px;
            font-weight: 600;
            margin: 0;
            color: #fff;
        }

        .product-rating {
            display: flex;
            gap: 4px;
            color: #fbbf24;
            font-size: 12px;
        }

        .product-price {
            font-size: 18px;
            font-weight: 700;
            color: #3b82f6;
            margin: 0;
        }

        /* Media Queries */
        @media (max-width: 1200px) {
            .hero-section {
                padding: 60px 32px;
            }
            .hero-tagline {
                font-size: 40px;
            }
            .products-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 24px;
            }
            .moon-bg {
                width: 400px;
                height: 400px;
            }
        }

        @media (max-width: 992px) {
            .hero-tagline {
                font-size: 32px;
            }
            .explore-section {
                padding: 60px 32px;
            }
        }

        @media (max-width: 768px) {
            .hero-section {
                flex-direction: column;
                text-align: center;
                padding: 60px 24px;
                min-height: auto;
                gap: 40px;
            }
            
            .hero-content {
                max-width: 100%;
            }

            .hero-tagline {
                font-size: 28px;
                letter-spacing: 1px;
            }

            .hero-image-container img {
                max-width: 80%;
            }

            .products-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }

            .section-title {
                margin-bottom: 40px;
                font-size: 20px;
            }
        }

        @media (max-width: 480px) {
            .hero-section {
                padding: 40px 16px;
            }

            .hero-tagline {
                font-size: 24px;
            }

            .explore-section {
                padding: 40px 16px;
            }

            .products-grid {
                grid-template-columns: 1fr;
                max-width: 340px;
                margin: 0 auto;
                gap: 32px;
            }

            .product-card {
                padding: 20px;
            }

            .moon-bg {
                width: 300px;
                height: 300px;
            }
        }
    </style>
</head>
<body>
    <%- include('user/partials/userNavbar') %>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <!-- Dynamic hero tagline data from backend -->
            <h1 class="hero-tagline">'Crafted for those who value every moment.'</h1>
        </div>
        <div class="hero-image-container">
            <div class="moon-bg"></div>
            <!-- Dynamic hero image from backend -->
            <img src="/assets/heroImage.png" alt="Hero Watch">
        </div>

    </section>

    <!-- Explore More Section -->
    <section class="explore-section">
        <h2 class="section-title">Explore More</h2>
        
        <div class="products-grid">

            
            <% products.forEach((product, index) => { %>
                <div class="product-card" onclick="window.location.href='/products/<%= product._id %>'">
                    <div class="product-image">
                        <!-- Dynamic product image from backend -->
                        <img src="<%= product.variants[0].mainImage.url %>" alt="<%= product.name %>">
                    </div>
                    <h3 class="product-name"><%= product.name %></h3>
                    <div class="product-rating">
                        <% for(let i = 0; i < (product.rating || 5); i++) { %>
                            <i class="fas fa-star"></i>
                        <% } %>
                    </div>
                    <p class="product-price">
                        <% if (product.variants && product.variants.length > 0) { %>
                            ₹<%= product.variants[0].price.toLocaleString('en-IN') %>
                        <% } else { %>
                            Price on Request
                        <% } %>
                    </p>
                </div>
            <% }); %>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <!-- Exclusive Section -->
            <div class="footer-section">
                <h3>Exclusive</h3>
                <h4 style="font-size: 14px; margin-bottom: 10px;">Subscribe</h4>
                <p style="color: #999; font-size: 13px; margin-bottom: 12px;">Get 10% off your first order</p>
                <div class="subscription-box">
                    <input type="email" placeholder="Enter your email">
                    <button><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>

            <!-- Support Section -->
            <div class="footer-section">
                <h3>Support</h3>
                <ul>
                    <li>9th Floor, Orion Business Park, Thane West, Mumbai, Maharashtra 400607</li>
                    <li><a href="mailto:'nexoratech@gmail.com">'nexoratech@gmail.com' </a></li>
                    <li><a href="tel: +91 22 4973 4581 ">+91 22 4973 4581</a></li>
                </ul>
            </div>

            <!-- Account Section -->
            <div class="footer-section">
                <h3>Account</h3>
                <ul>
                    <li><a href="/account">My Account</a></li>
                    <li><a href="/auth">Login / Register</a></li>
                    <li><a href="/cart">Cart</a></li>
                    <li><a href="/wishlist">Wishlist</a></li>
                    <li><a href="/shop">Shop</a></li>
                </ul>
            </div>

            <!-- Quick Link Section -->
            <div class="footer-section">
                <h3>Quick Link</h3>
                <ul>
                    <li><a href="/privacy">Privacy Policy</a></li>
                    <li><a href="/terms">Terms Of Use</a></li>
                    <li><a href="/faq">FAQ</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>

            <!-- Download App Section -->
            <div class="footer-section">
                <h3>Download App</h3>
                <p style="color: #999; font-size: 13px; margin-bottom: 12px;">Save with App New User Only</p>
                <div class="qr-code">
                    <!-- QR Code placeholder - replace with actual QR image -->
                    <span style="color: #000; font-size: 12px;">QR Code</span>
                </div>
                <div class="app-downloads">
                    <a href="/" class="app-btn">
                        <i class="fab fa-google-play"></i>
                        <span>Google Play</span>
                    </a>
                    <a href="" class="app-btn">
                        <i class="fab fa-app-store"></i>
                        <span>App Store</span>
                    </a>
                </div>
                <div class="social-links">
                    <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="#" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; Copyright Rimel 2022. All right reserved</p>
        </div>
    </footer>

</body>
</html>
