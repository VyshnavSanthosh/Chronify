    <script>
        // Product data from backend
        const productData = <%- JSON.stringify(product) %>;
        let currentVariantIndex = 0;
        let currentImageIndex = 0;
        let allImages = [];

        // Color mapping for display
        const colorMap = {
            'Blue': '#3b82f6',
            'Green': '#22c55e',
            'Gold': '#fbbf24',
            'Rose Gold': '#c77d56',
            'Red': '#ef4444',
            'Black': '#000000',
            'Silver': '#c0c0c0',
            'White': '#ffffff'
        };

        // Initialize the page
        function init() {
            updateGallery();
            populateColorOptions();
            populateStrapOptions();
        }

        function updateGallery() {
            const variant = productData.variants[currentVariantIndex];
            allImages = [variant.mainImage, ...variant.additionalImages];
            
            const gallery = document.getElementById('gallery');
            gallery.innerHTML = '';
            
            allImages.forEach((image, index) => {
                const thumb = document.createElement('div');
                thumb.className = `gallery-thumb ${index === currentImageIndex ? 'active' : ''}`;
                thumb.onclick = () => changeImage(index);
                thumb.innerHTML = `<img src="${image.url}" alt="Image ${index + 1}">`;
                gallery.appendChild(thumb);
            });
        }

        function populateColorOptions() {
            const colors = [...new Set(productData.variants.map(v => v.color))];
            const colorOptions = document.getElementById('colorOptions');
            colorOptions.innerHTML = '';
            
            colors.forEach(color => {
                const colorDiv = document.createElement('div');
                const bgColor = colorMap[color] || '#666';
                const isActive = productData.variants[currentVariantIndex].color === color;
                colorDiv.className = `color-option ${isActive ? 'active' : ''}`;
                colorDiv.style.background = bgColor;
                colorDiv.title = color;
                colorDiv.onclick = () => selectColor(color);
                colorOptions.appendChild(colorDiv);
            });
        }

        function populateStrapOptions() {
            const currentColor = productData.variants[currentVariantIndex].color;
            const straps = productData.variants
                .filter(v => v.color === currentColor)
                .map(v => v.strapMaterial);
            
            const strapOptions = document.getElementById('strapOptions');
            strapOptions.innerHTML = '';
            
            straps.forEach(strap => {
                const btn = document.createElement('button');
                const isActive = productData.variants[currentVariantIndex].strapMaterial === strap;
                btn.className = `strap-option ${isActive ? 'active' : ''}`;
                btn.textContent = strap;
                btn.onclick = () => selectStrap(strap);
                strapOptions.appendChild(btn);
            });
        }

        function selectColor(color) {
            const currentStrap = productData.variants[currentVariantIndex].strapMaterial;
            const newVariant = productData.variants.find(v => 
                v.color === color && v.strapMaterial === currentStrap
            ) || productData.variants.find(v => v.color === color);
            
            if (newVariant) {
                currentVariantIndex = productData.variants.indexOf(newVariant);
                currentImageIndex = 0;
                updateVariantDisplay();
            }
        }

        function selectStrap(strap) {
            const currentColor = productData.variants[currentVariantIndex].color;
            const newVariant = productData.variants.find(v => 
                v.color === currentColor && v.strapMaterial === strap
            );
            
            if (newVariant) {
                currentVariantIndex = productData.variants.indexOf(newVariant);
                currentImageIndex = 0;
                updateVariantDisplay();
            }
        }

        function updateVariantDisplay() {
            
            const variant = productData.variants[currentVariantIndex];
            const categoryOffer = productData.category.discountValue
            // Update price with offer calculation
            let offer = 0
            if (categoryOffer > variant.offer) {
                offer = categoryOffer
            }
            else{
                offer = variant.offer
            }
            
            const originalPrice = variant.price;
            const offerPrice = originalPrice - (originalPrice * offer / 100);
            
            const priceElement = document.getElementById('variantPrice');
            if (offer > 0) {
                priceElement.innerHTML = `
                    <span class="original-price">₹${Math.round(originalPrice).toLocaleString('en-IN')}</span>
                    <span class="offer-price">₹${Math.round(offerPrice).toLocaleString('en-IN')}</span>
                    <span class="offer-badge">${offer}% OFF</span>
                `;
            } else {
                priceElement.innerHTML = `<span class="offer-price">₹${Math.round(originalPrice).toLocaleString('en-IN')}</span>`;
            }
            
            // Update stock status
            const stockStatus = document.getElementById('stockStatus');
            const addToCartBtn = document.getElementById('addToCartBtn');
            
            if (variant.quantity === 0) {
                stockStatus.className = 'stock-status out-of-stock';
                stockStatus.textContent = 'Out of stock';
                addToCartBtn.disabled = true;
                addToCartBtn.textContent = 'Out of Stock';
            } else if (variant.quantity < 10) {
                stockStatus.className = 'stock-status low-stock';
                stockStatus.textContent = `Only ${variant.quantity} left`;
                addToCartBtn.disabled = false;
                addToCartBtn.textContent = 'Add To Cart';
            } else {
                stockStatus.className = 'stock-status in-stock';
                stockStatus.textContent = 'In Stock';
                addToCartBtn.disabled = false;
                addToCartBtn.textContent = 'Add To Cart';
            }
            
            // Update selected labels
            document.getElementById('selectedColor').textContent = variant.color;
            document.getElementById('selectedStrap').textContent = variant.strapMaterial;
            
            // Update main image
            document.getElementById('mainImage').src = variant.mainImage.url;
            
            // Update gallery
            updateGallery();
            populateColorOptions();
            populateStrapOptions();
        }

        function changeImage(index) {
            currentImageIndex = index;
            document.getElementById('mainImage').src = allImages[index].url;
            
            document.querySelectorAll('.gallery-thumb').forEach((thumb, i) => {
                thumb.classList.toggle('active', i === index);
            });
        }

        function nextImage() {
            currentImageIndex = (currentImageIndex + 1) % allImages.length;
            changeImage(currentImageIndex);
        }

        function previousImage() {
            currentImageIndex = (currentImageIndex - 1 + allImages.length) % allImages.length;
            changeImage(currentImageIndex);
        }

async function toggleWishlist() {
    console.log("clicked")
    
    const btn = document.querySelector('.wishlist-btn');
    const icon = btn.querySelector('i');
    const productId = productData._id;
    const variant = productData.variants[currentVariantIndex];
    const sku = variant.sku;
    const isHeartFilled = icon.classList.contains('fas');

    try {
        let response;
        if (isHeartFilled) {
            response = await fetch(`/wishlist/remove/${productId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });
        } else {
            response = await fetch(`/wishlist/add/${productId}?sku=${sku}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
        }
        
        const data = await response.json();

        if (response.ok && data.success) {
            if (isHeartFilled) {
                btn.style.backgroundColor = '';
                icon.classList.replace('fas', 'far');
                Swal.fire({
                    icon: 'success',
                    title: 'Removed from Wishlist',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#1a2855',
                    color: '#fff'
                });
            } else {
                btn.style.backgroundColor = '#ef4444';
                icon.classList.replace('far', 'fas');
                 Swal.fire({
                    icon: 'success',
                    title: 'Added to Wishlist',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#1a2855',
                    color: '#fff'
                });
            }
        } else {
              Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: data.message || 'Failed to update wishlist',
                background: '#1a2855',
                color: '#fff'
            });
        }
    } catch (error) {
         console.error('Error:', error);
         Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'An error occurred',
            background: '#1a2855',
            color: '#fff'
        });
    }
}


async function addToCart() {
    const variant = productData.variants[currentVariantIndex];

    if (variant.quantity === 0) return;

    const productId = productData._id;
    const sku = variant.sku || variant._id; // fallback if SKU doesn't exist

    try {
        const response = await fetch(`/cart/add/${productId}/${sku}`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                quantity: 1
            })
        });

        const result = await response.json();

        if (!response.ok) {
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: result.message || "Failed to add to cart",
                background: '#1a2855',
                color: '#fff',
                confirmButtonColor: '#3b82f6'
            });
            return;
        }

        Swal.fire({
            icon: 'success',
            title: 'Added!',
            text: 'Item added to cart successfully',
            background: '#1a2855',
            color: '#fff',
            confirmButtonColor: '#3b82f6'
        });

        console.log("Cart response:", result);

    } catch (error) {
        console.error("Add to cart error:", error);
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: "Something went wrong. Please try again.",
            background: '#1a2855',
            color: '#fff',
            confirmButtonColor: '#3b82f6'
        });
    }
}


        // Initialize hover zoom
        function initZoom() {
            const mainImageContainer = document.querySelector('.main-image');
            const mainImage = document.getElementById('mainImage');

            if (!mainImageContainer || !mainImage) return;

            mainImageContainer.addEventListener('mousemove', (e) => {
                // Get the bounding rectangle of the container
                const rect = mainImageContainer.getBoundingClientRect();
                
                // Calculate mouse position relative to the container
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                // Set the transform origin to the mouse position
                mainImage.style.transformOrigin = `${x}px ${y}px`;
                mainImage.style.transform = "scale(2.5)";
            });

            mainImageContainer.addEventListener('mouseleave', () => {
                mainImage.style.transformOrigin = "center";
                mainImage.style.transform = "scale(1)";
            });
        }

        // Initialize on page load
        init();
        initZoom();


    </script>
</body>
