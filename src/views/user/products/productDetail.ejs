<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product?.name || 'Product Details' %> - Chronify</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #050a14 0%, #0f172a 100%);
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
        }

        /* Header */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background: rgba(5, 10, 20, 0.95);
            border-bottom: 1px solid #1a2f4d;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 2px;
            cursor: pointer;
        }

        .header-links {
            display: flex;
            gap: 40px;
        }

        .header-links a {
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: color 0.3s;
        }

        .header-links a:hover {
            color: #3b82f6;
        }

        .header-icons {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .icon-btn {
            background: none;
            border: none;
            color: #fff;
            cursor: pointer;
            font-size: 18px;
            transition: color 0.3s;
            position: relative;
        }

        .hamburger-btn {
            display: none;
        }

        .mobile-nav {
            display: none;
            background: #000;
            padding: 24px;
            flex-direction: column;
            gap: 16px;
            border-bottom: 2px solid #3b82f6;
            animation: slideDown 0.3s ease-out;
            width: 100%;
            position: sticky;
            top: 73px; /* Default Header height */
            z-index: 999;
        }

        @media (max-width: 768px) {
            .mobile-nav {
                top: 60px; /* Adjusted for smaller header padding */
            }
        }
            .header-center {
                display: none;
            }

        .mobile-nav.active {
            display: flex;
        }

        .mobile-nav a {
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 2px;
            padding-bottom: 4px;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Main Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px;
        }

        /* Product Section */
        .product-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            margin-bottom: 80px;
        }

        .product-images {
            position: relative;
        }

        .main-image {
            width: 100%;
            height: 500px;
            background: #0f172a;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            margin-bottom: 20px;
        }

        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: transform 0.3s ease;
            transform-origin: center;
        }

        .wishlist-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(59, 130, 246, 0.8);
            border: none;
            color: #fff;
            cursor: pointer;
            font-size: 18px;
            transition: all 0.3s;
        }

        .wishlist-btn:hover {
            background: #3b82f6;
            transform: scale(1.1);
        }

        .nav-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 40px;
            height: 40px;
            background: rgba(59, 130, 246, 0.7);
            border: none;
            color: #fff;
            cursor: pointer;
            border-radius: 4px;
            font-size: 18px;
            transition: background 0.3s;
            z-index: 10;
        }

        .nav-arrow:hover {
            background: rgba(59, 130, 246, 0.9);
        }

        .nav-arrow.prev {
            left: 20px;
        }

        .nav-arrow.next {
            right: 20px;
        }

        .gallery {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            scrollbar-width: none; /* Firefox */
            -ms-overflow-style: none;  /* IE and Edge */
            padding-bottom: 4px;
        }

        .gallery::-webkit-scrollbar {
            display: none; /* Chrome, Safari, Opera */
        }

        .gallery-thumb {
            flex: 0 0 80px;
            height: 80px;
            border: 2px solid transparent;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            background: #0f172a;
            transition: border-color 0.3s;
        }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .gallery-thumb:hover,
        .gallery-thumb.active {
            border-color: #3b82f6;
        }

        /* Product Info */
        .product-info h1 {
            font-size: 42px;
            margin-bottom: 20px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .price-rating {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 30px;
        }

        .price {
            font-size: 32px;
            font-weight: bold;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .original-price {
            font-size: 24px;
            font-weight: 500;
            color: #9ca3af;
            text-decoration: line-through;
        }

        .offer-price {
            font-size: 32px;
            font-weight: bold;
            color: #fff;
        }

        .offer-badge {
            display: inline-block;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: #fff;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .rating {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stars {
            color: #fbbf24;
            font-size: 18px;
        }

        .review-count {
            color: #9ca3af;
            font-size: 14px;
        }

        .stock-status {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            margin-left: 20px;
        }

        .stock-status.out-of-stock {
            background: rgba(248, 113, 113, 0.2);
            color: #f87171;
            border: 1px solid #f87171;
        }

        .stock-status.low-stock {
            background: rgba(251, 191, 36, 0.2);
            color: #fbbf24;
            border: 1px solid #fbbf24;
        }

        .stock-status.in-stock {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid #22c55e;
        }

        .description {
            margin: 30px 0;
            line-height: 1.8;
            color: #d1d5db;
            font-size: 14px;
        }

        .description-section {
            margin: 80px 0;
        }

        .description-content {
            background: linear-gradient(135deg, #1a2855 0%, #0f1a35 100%);
            border: 1px solid #2a3f66;
            border-radius: 12px;
            padding: 40px;
        }

        .description-content p {
            line-height: 1.8;
            color: #d1d5db;
            font-size: 15px;
            margin-bottom: 16px;
        }

        /* Related Products */
        .related-products {
            margin: 80px 0;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 40px;
        }

        .product-card {
            background: linear-gradient(135deg, #1a2855 0%, #0f1a35 100%);
            border: 1px solid #2a3f66;
            border-radius: 12px;
            padding: 24px;
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .product-card:hover {
            border-color: #3b82f6;
            transform: translateY(-6px);
        }

        .card-image {
            width: 100%;
            height: 280px;
            background: #000;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .card-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .card-brand {
            font-size: 12px;
            color: #9ca3af;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #fff;
        }

        .card-price {
            font-size: 20px;
            font-weight: 700;
            color: #3b82f6;
            margin-bottom: 12px;
        }

        .card-stock {
            font-size: 13px;
            padding: 6px 12px;
            border-radius: 4px;
            display: inline-block;
        }

        .card-stock.in-stock {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
        }

        .card-stock.low-stock {
            background: rgba(251, 191, 36, 0.2);
            color: #fbbf24;
        }

        .card-stock.out-of-stock {
            background: rgba(248, 113, 113, 0.2);
            color: #f87171;
        }

        .product-options {
            margin: 40px 0;
        }

        .option-group {
            margin-bottom: 30px;
        }

        .option-label {
            font-weight: 600;
            margin-bottom: 12px;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }

        .option-values {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .color-option {
            width: 40px;
            height: 40px;
            border-radius: 6px;
            border: 2px solid #444;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .color-option:hover,
        .color-option.active {
            border-color: #3b82f6;
        }

        .color-option.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .strap-option {
            padding: 10px 16px;
            border: 1px solid #444;
            border-radius: 6px;
            background: transparent;
            color: #fff;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 12px;
        }

        .strap-option:hover,
        .strap-option.active {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.1);
        }

        .strap-option.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .add-to-cart {
            width: 200px;
            padding: 14px 0;
            background: #3b82f6;
            border: none;
            color: #fff;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: background 0.3s;
            margin-top: 30px;
        }

        .add-to-cart:hover {
            background: #2563eb;
        }

        .add-to-cart:disabled {
            background: #6b7280;
            cursor: not-allowed;
        }

        /* Specifications Section */
        .specifications {
            margin: 80px 0;
        }

        .section-title {
            font-size: 32px;
            margin-bottom: 40px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .specs-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
        }

        .spec-category {
            margin-bottom: 40px;
        }

        .spec-category h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .spec-category ul {
            list-style: none;
        }

        .spec-category li {
            margin-bottom: 10px;
            color: #d1d5db;
            font-size: 14px;
        }

        /* Footer */
        footer {
            background: #000;
            padding: 60px 40px 30px;
            margin-top: 80px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 40px;
            margin-bottom: 60px;
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }

        .footer-col h3 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 24px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li {
            margin-bottom: 12px;
            font-size: 13px;
            color: #d1d5db;
        }

        .footer-col ul li a {
            color: #d1d5db;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-col ul li a:hover {
            color: #3b82f6;
        }

        .subscribe-input {
            display: flex;
            margin-top: 16px;
        }

        .subscribe-input input {
            flex: 1;
            padding: 10px 12px;
            background: transparent;
            border: 1px solid #444;
            color: #fff;
            border-radius: 0;
            font-size: 12px;
        }

        .subscribe-input button {
            padding: 10px 16px;
            background: transparent;
            border: 1px solid #444;
            color: #fff;
            cursor: pointer;
            border-radius: 0;
            transition: all 0.3s;
        }

        .subscribe-input button:hover {
            background: #3b82f6;
            border-color: #3b82f6;
        }

        .footer-bottom {
            border-top: 1px solid #1a2f4d;
            padding-top: 30px;
            text-align: center;
            color: #6b7280;
            font-size: 12px;
        }

        @media (max-width: 1024px) {
            .container {
                padding: 30px;
            }

            .product-section {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .specs-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .products-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }

            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            header {
                padding: 12px 20px;
            }

            .header-links {
                display: none;
            }

            .hamburger-btn {
                display: flex;
            }

            .logo {
                font-size: 20px;
            }

            .container {
                padding: 20px;
            }

            .main-image {
                height: 400px;
            }

            .product-info h1 {
                font-size: 32px;
            }

            .price-rating {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .stock-status {
                margin-left: 0;
            }

            .section-title {
                font-size: 28px;
                margin-bottom: 24px;
            }

            .products-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 576px) {
            .main-image {
                height: 300px;
            }

            .product-info h1 {
                font-size: 26px;
            }

            .price {
                font-size: 24px;
            }

            .offer-price {
                font-size: 24px;
            }

            .original-price {
                font-size: 18px;
            }

            .gallery-thumb {
                flex: 0 0 60px;
                height: 60px;
            }

            .add-to-cart {
                width: 100%;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .description-content {
                padding: 20px;
            }

            .specs-grid {
                gap: 20px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/userNavbar') %>

    <!-- Main Container -->
    <div class="container">
        <!-- Product Section -->
        <section class="product-section">
            <div class="product-images">
                <div class="main-image">
                    <button class="nav-arrow prev" onclick="previousImage()"><i class="fas fa-chevron-left"></i></button>
                    <img id="mainImage" src="<%= product?.variants[0]?.mainImage?.url || '/images/default-watch.jpg' %>" alt="<%= product?.name || 'Product' %>">
                    <button class="nav-arrow next" onclick="nextImage()"><i class="fas fa-chevron-right"></i></button>
                    <button class="wishlist-btn" onclick="toggleWishlist()" style="<%= typeof isWishlisted !== 'undefined' && isWishlisted ? 'background-color: #ef4444;' : '' %>">
                        <i class="<%= typeof isWishlisted !== 'undefined' && isWishlisted ? 'fas' : 'far' %> fa-heart"></i>
                    </button>
                </div>

                <div class="gallery" id="gallery">
                    <!-- Gallery will be populated by JavaScript -->
                </div>
            </div>

            <div class="product-info">
                <h1><%= product?.name || 'Product Name' %></h1>

                <div class="price-rating">
                    <% 
                        const firstVariant = product?.variants[0];
                        const originalPrice = firstVariant?.price || 0;
                        const offer = firstVariant?.offer || 0;
                        const offerPrice = originalPrice - (originalPrice * offer / 100);
                    %>
                    <div class="price" id="variantPrice">
                        <% if (offer > 0) { %>
                            <span class="original-price">₹<%= Math.round(originalPrice).toLocaleString('en-IN') %></span>
                            <span class="offer-price">₹<%= Math.round(offerPrice).toLocaleString('en-IN') %></span>
                            <span class="offer-badge"><%= offer %>% OFF</span>
                        <% } else { %>
                            <span class="offer-price">₹<%= Math.round(originalPrice).toLocaleString('en-IN') %></span>
                        <% } %>
                    </div>
                    <% 
                        const currentVariant = product?.variants[0];
                        const quantity = currentVariant?.quantity || 0;
                        let stockClass = 'in-stock';
                        let stockText = 'In Stock';
                        
                        if (quantity === 0) {
                            stockClass = 'out-of-stock';
                            stockText = 'Out of stock';
                        } else if (quantity < 10) {
                            stockClass = 'low-stock';
                            stockText = `Only ${quantity} left`;
                        }
                    %>
                    <span class="stock-status <%= stockClass %>" id="stockStatus"><%= stockText %></span>
                </div>

                <div class="description">
                    <p><%= product?.description || 'No description available.' %></p>
                </div>

                <div class="product-options">
                    <div class="option-group">
                        <div class="option-label">Color: <span id="selectedColor"><%= product?.variants[0]?.color || '' %></span></div>
                        <div class="option-values" id="colorOptions">
                            <!-- Color options will be populated by JavaScript -->
                        </div>
                    </div>

                    <div class="option-group">
                        <div class="option-label">Strap Material: <span id="selectedStrap"><%= product?.variants[0]?.strapMaterial || '' %></span></div>
                        <div class="option-values" id="strapOptions">
                            <!-- Strap options will be populated by JavaScript -->
                        </div>
                    </div>
                </div>

                <button class="add-to-cart" id="addToCartBtn" onclick="addToCart()" <%= product.variants[0].quantity === 0 ? 'disabled' : '' %>>
                    <%= product.variants[0].quantity === 0 ? 'Out of Stock' : 'Add To Cart' %>
                </button>
            </div>
        </section>

        <!-- Specifications -->
        <section class="specifications">
            <h2 class="section-title">Specifications</h2>

            <div class="specs-grid">
                <div>
                    <div class="spec-category">
                        <h3>Product Details</h3>
                        <ul>
                            <li>• Brand: <%= product?.brand || 'N/A' %></li>
                            <li>• Model: <%= product?.name || 'N/A' %></li>
                            <% if (product?.specifications?.weight) { %>
                                <li>• Weight: <%= product.specifications.weight %></li>
                            <% } %>
                            <% if (product?.specifications?.waterResistance) { %>
                                <li>• Water Resistance: <%= product.specifications.waterResistance %></li>
                            <% } %>
                            <% if (product?.specifications?.warranty) { %>
                                <li>• Warranty: <%= product.specifications.warranty %></li>
                            <% } %>
                        </ul>
                    </div>
                </div>

                <div>
                    <div class="spec-category">
                        <h3>Available Variants</h3>
                        <ul>
                            <% if (product?.variants) { %>
                                <% product.variants.forEach((variant, index) => { %>
                                    <li>• <%= variant.color %> - <%= variant.strapMaterial %> (₹<%= Math.round(variant.price) %>)</li>
                                <% }); %>
                            <% } else { %>
                                <li>No variants available</li>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Description Section -->
        <section class="description-section">
            <h2 class="section-title">Description</h2>
            <div class="description-content">
                <p><%= product?.description || 'No detailed description available for this product.' %></p>
                
                <% if (product?.specifications) { %>
                    <p style="margin-top: 24px;">
                        <strong>Additional Features:</strong><br>
                        This timepiece combines exceptional craftsmanship with modern functionality. 
                        <% if (product.specifications.waterResistance) { %>
                            With <%= product.specifications.waterResistance %> water resistance, it's built to withstand daily wear and various conditions.
                        <% } %>
                        <% if (product.specifications.warranty) { %>
                            Backed by a <%= product.specifications.warranty %> warranty, ensuring peace of mind with your purchase.
                        <% } %>
                    </p>
                <% } %>
            </div>
        </section>

        <!-- Related Products -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <section class="related-products">
                <h2 class="section-title">Related Products</h2>
                
                <div class="products-grid">
                    <% relatedProducts.slice(0, 3).forEach(relatedProduct => { 
                        const firstVariant = relatedProduct.variants[0];
                        const quantity = firstVariant?.quantity || 0;
                        let stockClass = 'in-stock';
                        let stockText = 'In Stock';
                        
                        if (quantity === 0) {
                            stockClass = 'out-of-stock';
                            stockText = 'Out of stock';
                        } else if (quantity < 10) {
                            stockClass = 'low-stock';
                            stockText = `Only ${quantity} left`;
                        }
                    %>
                        <a href="/products/<%= relatedProduct._id %>" class="product-card">
                            <div class="card-image">
                                <img src="<%= firstVariant?.mainImage?.url || '/images/default-watch.jpg' %>" alt="<%= relatedProduct.name %>">
                            </div>
                            <div class="card-brand"><%= relatedProduct.brand %></div>
                            <div class="card-title"><%= relatedProduct.name %></div>
                            <% 
const relatedOriginalPrice = firstVariant?.price || 0;
let relatedOffer = 0
if(product.category.discountValue > firstVariant.offer){
        relatedOffer = product.category.discountValue
    }
else{
    relatedOffer = firstVariant.offer
    }               
const relatedOfferPrice = relatedOriginalPrice - (relatedOriginalPrice * relatedOffer / 100);
                            %>
                            <div class="card-price" style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                <% if (relatedOffer > 0) { %>
