    <script>
        // State management
        let currentPage = <%= page || 1 %>;
        let totalProducts = <%= totalProducts || 0 %>;
        const itemsPerPage = 12;
        let totalPages = Math.ceil(totalProducts / itemsPerPage);
        let isLoading = false;

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            updatePaginationUI();
            attachEventListeners();

            // Check for messages in URL
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            if (message === 'blocked') {
                console.log("blocked")
                
                Swal.fire({
                    icon: 'warning',
                    title: 'Availability Update',
                    text: 'This product is not available right now.',
                    background: '#0f1a35',
                    color: '#fff',
                    confirmButtonColor: '#3b82f6'
                });
                
                const newUrl = window.location.pathname + window.location.search.replace(/[?&]message=blocked/, '').replace(/^&/, '?');
                window.history.replaceState({}, '', newUrl);
            }
        });

        // Attach event listeners
        function attachEventListeners() {
            // Search form submission
            document.getElementById('searchForm').addEventListener('submit', function(e) {
                e.preventDefault();
                applyFilters();
            });

            // Filter form submission
            document.getElementById('filterForm').addEventListener('submit', function(e) {
                e.preventDefault();
                applyFilters();
            });

            // Filter changes
            const filterInputs = document.querySelectorAll('#filterForm input[type="radio"]');
            filterInputs.forEach(input => {
                input.addEventListener('change', applyFilters);
            });
        }

        // Apply filters and fetch products
        async function applyFilters() {
            if (isLoading) return;
            
            currentPage = 1; // Reset to first page on filter change
            await fetchProducts();
        }

        // Fetch products via AJAX
        async function fetchProducts() {
            if (isLoading) return;
            isLoading = true;

            const search = document.getElementById('headerSearch').value;
            const category = document.querySelector('input[name="category"]:checked')?.value || 'All';
            const brand = document.querySelector('input[name="brand"]:checked')?.value || 'All';
            const sort = document.querySelector('input[name="sort"]:checked')?.value || '';

            // Build query parameters
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            if (category && category !== 'All') params.append('category', category);
            if (brand && brand !== 'All') params.append('brand', brand);
            if (sort) params.append('sort', sort);
            params.append('page', currentPage);

            try {
                // Show loading state
                const grid = document.getElementById('productsGrid');
                grid.innerHTML = '<div class="loading"><i class="fa-solid fa-spinner fa-spin"></i> Loading...</div>';

                const response = await fetch(`/products?${params.toString()}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }

                const html = await response.text();
                
                // Parse the HTML response
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                // Extract the products grid
                const newGrid = doc.getElementById('productsGrid');
                if (newGrid) {
                    grid.innerHTML = newGrid.innerHTML;
                }

                // Update total products count (you may need to add a hidden element for this)
                // For now, we'll keep the existing total
                
                // Pagination doesn't need re-loading wishlist state from localStorage anymore
                // as the new HTML grid from server already has the correct icon states
                updatePaginationUI();

                // Update URL without reload
                const newUrl = `/products?${params.toString()}`;
                window.history.pushState({}, '', newUrl);

            } catch (error) {
                console.error('Error fetching products:', error);
                const grid = document.getElementById('productsGrid');
                grid.innerHTML = '<div class="no-products"><i class="fas fa-exclamation-circle"></i><h3>Error loading products</h3><p>Please try again later</p></div>';
            } finally {
                isLoading = false;
            }
        }

        // Update pagination UI
        function updatePaginationUI() {
            const container = document.getElementById('paginationContainer');
            container.innerHTML = '';

            if (totalPages === 0 || totalProducts === 0) return;

            // Previous button
            const prevBtn = document.createElement('button');
            prevBtn.innerHTML = '<i class="fas fa-chevron-left"></i>';
            prevBtn.disabled = currentPage === 1;
            prevBtn.onclick = () => goToPage(currentPage - 1);
            container.appendChild(prevBtn);

            // Page numbers - show first page, current page area, and last page
            const maxVisiblePages = 5;
            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

            // Adjust if near the end
            if (endPage - startPage < maxVisiblePages - 1) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            // Always show first page
            if (startPage > 1) {
                const firstBtn = document.createElement('button');
                firstBtn.textContent = '1';
                firstBtn.onclick = () => goToPage(1);
                container.appendChild(firstBtn);

                if (startPage > 2) {
                    const dots = document.createElement('button');
                    dots.textContent = '...';
                    dots.disabled = true;
                    container.appendChild(dots);
                }
            }

            // Page buttons
            for (let i = startPage; i <= endPage; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.textContent = i;
                pageBtn.className = i === currentPage ? 'active' : '';
                pageBtn.onclick = () => goToPage(i);
                container.appendChild(pageBtn);
            }

            // Show last page if needed
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    const dots = document.createElement('button');
                    dots.textContent = '...';
                    dots.disabled = true;
                    container.appendChild(dots);
                }

                const lastBtn = document.createElement('button');
                lastBtn.textContent = totalPages;
                lastBtn.onclick = () => goToPage(totalPages);
                container.appendChild(lastBtn);
            }

            // Next button
            const nextBtn = document.createElement('button');
            nextBtn.innerHTML = '<i class="fas fa-chevron-right"></i>';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.onclick = () => goToPage(currentPage + 1);
            container.appendChild(nextBtn);
        }

        // Go to specific page
        async function goToPage(page) {
            if (page < 1 || page > totalPages || page === currentPage || isLoading) {
                return;
            }
            currentPage = page;
            await fetchProducts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Filters and Wishlist functionality
        function clearFilters() {
            // Reset forms
            document.getElementById('filterForm').reset();
            document.getElementById('headerSearch').value = '';
            
            // Ensure all radio buttons are reset to their default state
            const radios = document.querySelectorAll('#filterForm input[type="radio"]');
            radios.forEach(radio => {
                if (radio.value === 'All' || radio.value === '') {
                    radio.checked = true;
                } else {
                    radio.checked = false;
                }
            });

            currentPage = 1;
            fetchProducts();
        }

        async function toggleWishlist(event, productId, sku) {
            event.preventDefault();
            event.stopPropagation();

            const iconContainer = event.currentTarget;
            const icon = iconContainer.querySelector('i');
            const isActive = iconContainer.classList.contains('active');

            try {
                let response;
                if (isActive) {
                    // Remove from wishlist
                    response = await fetch(`/wishlist/remove/${productId}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });
                } else {
                    // Add to wishlist
                    response = await fetch(`/wishlist/add/${productId}?sku=${sku}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                }

                const data = await response.json();

                if (response.ok && data.success) {
                    // Toggle UI
                    iconContainer.classList.toggle('active');
                    if (icon.classList.contains('fas')) {
                        icon.classList.replace('fas', 'far');
                    } else {
                        icon.classList.replace('far', 'fas');
                    }
                    
                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true,
                        background: '#1a2855',
                        color: '#fff',
                    });

                    Toast.fire({
                        icon: 'success',
                        title: isActive ? 'Removed from Wishlist' : 'Added to Wishlist'
                    });
                } else {
                     Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: data.message || 'Something went wrong!',
                        background: '#1a2855',
                        color: '#fff'
                    });
                }
            } catch (error) {
                console.error('Error toggling wishlist:', error);
                 Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to update wishlist',
                    background: '#1a2855',
                    color: '#fff'
                });
            }
        }
        document.addEventListener('DOMContentLoaded', function() {
            <% if (locals.blocked) { %>
                Swal.fire({
                    icon: 'warning',
                    title: 'Availability Update',
                    text: 'This product is not available right now.',
                    background: '#0f1a35',
                    color: '#fff',
                    confirmButtonColor: '#3b82f6'
                });
            <% } %>
        });


        function viewProduct(productId) {
            window.location.href = `/products/${productId}`;
        }
    </script>
</body>
</html>