<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - ChronoMy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/signup.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        @keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        .alert-dismissing {
            animation: fadeOut 0.5s ease-out forwards;
        }
    </style>
</head>

<body>
<div class="signup-container">
    <div class="signup-card">

        <h1 class="signup-heading">Create Account</h1>

        <!-- General Error -->
        <% if (errors && errors.general) { %>
            <div 
                class="alert alert-danger mb-4"
                role="alert"
                id="generalError">
                <%= errors.general %>
            </div>
        <% } %>

        <form action="/auth/signup" method="POST" id="signupForm" class="signup-form">

            <!-- Name -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">First Name</label>
                    <input class="form-control signup-input" name="firstName" value="<%= firstName || '' %>">
                    <% if (errors?.firstName) { %>
                        <div class="error-text"><%= errors.firstName %></div>
                    <% } %>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Last Name</label>
                    <input class="form-control signup-input" name="lastName" value="<%= lastName || '' %>">
                    <% if (errors?.lastName) { %>
                        <div class="error-text"><%= errors.lastName %></div>
                    <% } %>
                </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input
                    type="email"
                    class="form-control signup-input"
                    name="email"
                    placeholder="john.doe@example.com"
                    value="<%= email || '' %>"
                >
                <% if (errors?.email) { %>
                    <div class="error-text"><%= errors.email %></div>
                <% } %>
            </div>

            <!-- Phone -->
            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input
                    type="tel"
                    class="form-control signup-input"
                    name="phone"
                    maxlength="10"
                    value="<%= phone || '' %>"
                >
                <% if (errors?.phone) { %>
                    <div class="error-text"><%= errors.phone %></div>
                <% } %>
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        class="form-control signup-input" 
                        id="password"
                        name="password"
                        required
                    >
                    <button type="button" class="input-icon toggle-password-btn" onclick="togglePassword('password')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M8 3C4 3 1.19 5.19 1 8c.19 2.81 3 5 7 5s6.81-2.19 7-5c-.19-2.81-3-5-7-5zm0 8c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm0-5c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="#999"/>
                        </svg>
                    </button>
                </div>
                <small class="text-white">* At least 8 characters</small>
                <% if (errors?.password) { %>
                    <div class="error-text"><%= errors.password %></div>
                <% } %>
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        class="form-control signup-input" 
                        id="confirmPassword"
                        name="confirmPassword"
                        required
                    >
                    <button type="button" class="input-icon toggle-password-btn" onclick="togglePassword('confirmPassword')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M8 3C4 3 1.19 5.19 1 8c.19 2.81 3 5 7 5s6.81-2.19 7-5c-.19-2.81-3-5-7-5zm0 8c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm0-5c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="#999"/>
                        </svg>
                    </button>
                </div>
                <% if (errors?.confirmPassword) { %>
                    <div class="error-text"><%= errors.confirmPassword %></div>
                <% } %>
            </div>

            <!-- Referral -->
            <div class="mb-4">
                <input
                    class="form-control signup-input"
                    name="referralCode"
                    placeholder="Referral Code (optional)">
            </div>

            <button type="submit" class="btn btn-signup w-100 mb-3">
                Create Account
            </button>

            <div class="text-center mb-4">
                Already have an account?
                <a href="/auth/login" class="login-link">Log in</a>
            </div>

            <a href="/auth/google" class="btn btn-google w-100">Sign up with Google</a>
        </form>

        <p class="terms-text">
            By signing up, you agree to our
            <a href="/terms">Terms</a> and <a href="/privacy">Privacy Policy</a>
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Show SweetAlert messages if passed from backend
    <% if (locals.success) { %>
        Swal.fire({
            icon: 'success',
            title: 'Success!',
            text: '<%= locals.success %>',
            confirmButtonColor: '#28a745',
            timer: 3000,
            timerProgressBar: true
        });
    <% } %>

    <% if (locals.info) { %>
        Swal.fire({
            icon: 'info',
            title: 'Information',
            text: '<%= locals.info %>',
            confirmButtonColor: '#17a2b8'
        });
    <% } %>

    // ✅ Auto-dismiss general error EXACTLY in 3 seconds
    const generalError = document.getElementById("generalError");

    if (generalError) {
        // Start fade at 1.5s
        setTimeout(() => {
            generalError.classList.add("alert-dismissing");
        }, 1500);

        // Remove at 2s
        setTimeout(() => {
            generalError.remove();
        }, 2000);
    }

    // Toggle password visibility
    function togglePassword(fieldId) {
        const passwordInput = document.getElementById(fieldId);
        passwordInput.type = passwordInput.type === 'password' ? 'text' : 'password';
    }
</script>

</body>
</html>