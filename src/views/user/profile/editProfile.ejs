<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vendor Dashboard - Chronify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #050a14;
        }
        .sidebar-item-active {
            background-color: #4b5563;
        }
        .custom-dark-card {
            background-color: #0a192f;
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="text-white min-h-screen flex">

<!-- Sidebar -->
<aside class="w-64 bg-[#0a1425] flex flex-col border-r border-gray-800 hidden md:flex">
    <div class="p-6">
        <h1 class="text-2xl font-bold tracking-widest text-white uppercase italic">
            Chronify
        </h1>
    </div>

    <nav class="flex-1 px-4 space-y-2">
        <a href="/vendor/dashboard" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-house w-5 text-center"></i>
                <span class="text-sm font-medium">Dashboard</span>
            </div>
        </a>

        <a href="/vendor/products" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors sidebar-item-active text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-briefcase w-5 text-center"></i>
                <span class="text-sm font-medium">Products</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/vendor/orders" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-list-ul w-5 text-center"></i>
                <span class="text-sm font-medium">Order List</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/categories" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-table-cells-large w-5 text-center"></i>
                <span class="text-sm font-medium">Category</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/vendor/profile" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-circle-user w-5 text-center"></i>
                <span class="text-sm font-medium">Profile</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/wallet" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-wallet w-5 text-center"></i>
                <span class="text-sm font-medium">Wallet</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/returns" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-list-check w-5 text-center"></i>
                <span class="text-sm font-medium">Return/Refund List</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>

        <a href="/inventory" class="flex items-center justify-between px-4 py-3 rounded-lg transition-colors text-gray-400 hover:bg-gray-800 hover:text-white">
            <div class="flex items-center space-x-3">
                <i class="fa-solid fa-toolbox w-5 text-center"></i>
                <span class="text-sm font-medium">Inventory Management</span>
            </div>
            <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </a>
    </nav>

    <div class="p-6">
        <button class="w-full py-2 bg-white text-black font-semibold rounded-md hover:bg-gray-200 transition-colors">
            Logout
        </button>
    </div>
</aside>

<!-- Main Content -->
<main class="flex-1 flex flex-col">

<header class="h-16 flex items-center justify-end px-8 border-b border-gray-800">
    <div class="flex items-center space-x-3">
        <div class="text-right">
            <p class="text-sm font-semibold"><%= user.firstName || 'Vyshnav' %></p>
            <p class="text-xs text-gray-400 uppercase tracking-tighter"><%= user.role || 'Vendor' %></p>
        </div>
    </div>
</header>

<div class="flex-1 p-12 flex justify-center items-center">

<div class="w-full max-w-4xl custom-dark-card rounded-3xl p-12 shadow-2xl">

<div class="flex flex-col items-center text-center mb-10">

<h2 class="text-sm font-medium tracking-[0.2em] mb-4 uppercase">
Welcome <br>
<span class="text-xs opacity-70"><%= user.firstName || 'Casio' %></span>
</h2>

<!-- CLICKABLE PROFILE IMAGE -->
<div class="mb-4 relative cursor-pointer"
     onclick="document.getElementById('profileImageInput').click()">

    <img
        id="profileImagePreview"
        src="<%= user.profileImage || '/assets/userIcon.png' %>"
        alt="Brand Logo"
        class="w-20 h-20 rounded-xl bg-white p-1 object-cover"
    />

    <!-- Camera Overlay -->
    <div class="absolute bottom-0 right-0 bg-black bg-opacity-70 rounded-full p-1">
        <i class="fa-solid fa-camera text-xs"></i>
    </div>
</div>

</div>

<!-- FORM -->
<form action="/profile/edit"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6">

<!-- Hidden File Input -->
<input
    type="file"
    id="profileImageInput"
    name="profileImage"
    accept="image/*"
    class="hidden"
    onchange="previewImage(this)"
>

<div>
    <label class="block text-sm font-medium text-gray-300 mb-2">First Name</label>
    <input
        type="text"
        name="firstName"
        value="<%= user.firstName || 'Casio' %>"
        class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500">
</div>

<div>
    <label class="block text-sm font-medium text-gray-300 mb-2">Last Name</label>
    <input
        type="text"
        name="lastName"
        value="<%= user.lastName || 'Casio' %>"
        class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500">
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
        <div class="flex gap-2">
            <input
                type="email"
                id="emailInput"
                name="email"
                placeholder="Your email"
                value="<%= user.email || '' %>"
                <%= (typeof verified !== 'undefined' && verified) ? "" : "disabled" %>
                class="flex-1 <%= (typeof verified !== 'undefined' && verified) ? 'bg-white text-black' : 'bg-gray-200 text-gray-500 cursor-not-allowed opacity-60' %> px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500">
            
            <% if (typeof verified !== 'undefined' && verified) { %>
                <button
                    type="button"
                    class="bg-green-600 text-white px-4 py-3 rounded-md text-sm font-medium whitespace-nowrap cursor-default">
                    <i class="fa-solid fa-check mr-1"></i> Verified
                </button>
            <% } else { %>
                <button
                    type="button"
                    onclick="sendOtpAndRedirect()"
                    class="bg-yellow-500 text-black px-4 py-3 rounded-md text-sm font-medium whitespace-nowrap hover:bg-teal-600 transition-colors">
                    Verify to Edit
                </button>
            <% } %>

        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Phone Number</label>
        <input
            type="text"
            name="phone"
            placeholder="Phone Number"
            value="<%= user.phone || '' %>"
            class="w-full bg-white text-black px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500">
    </div>
</div>

<div>
    <button
        type="submit"
        class="bg-blue-500 text-white px-8 py-3 rounded-md text-sm font-medium transition-colors hover:bg-blue-600">
        Save
    </button>
</div>

</form>

</div>
</div>
</main>

<script src="/js/logout.js"></script>

<!-- IMAGE PREVIEW SCRIPT -->
<script>
function previewImage(input) {
    const file = input.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
        document.getElementById("profileImagePreview").src = e.target.result;
    };
    reader.readAsDataURL(file);
}
async function sendOtpAndRedirect() {
    try {
        const response = await fetch("/profile/send-otp", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        }
        });

        const data = await response.json();

        if (data.success) {
        window.location.href = "/profile/verify-otp";
        } else {
        Swal.fire("Error", data.message || "Failed to send OTP", "error");
        }
    } catch (err) {
        Swal.fire("Error", "Network error while sending OTP", "error");
    }
}
</script>

</body>
</html>