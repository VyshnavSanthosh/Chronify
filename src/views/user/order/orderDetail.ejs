    <script>
        async function cancelItem(orderId, sku) {
            if (!orderId || !sku) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Data',
                    text: 'Could not find a valid order ID or item SKU.'
                });
                return;
            }

            const result = await Swal.fire({
                title: 'Cancel this item?',
                text: "Are you sure you want to cancel this item?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#3b82f6',
                confirmButtonText: 'Yes, cancel it!'
            });

            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/<%= user._id %>/orders/${orderId}/items/${sku}/cancel`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });

                    const data = await res.json();

                    if (data.success) {
                        await Swal.fire(
                            'Cancelled!',
                            'The item has been cancelled successfully.',
                            'success'
                        );
                        location.reload();
                    } else {
                        Swal.fire(
                            'Failed!',
                            data.message || 'Failed to cancel item.',
                            'error'
                        );
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'An error occurred while cancelling the item.', 'error');
                }
            }
        }

        async function cancelOrder() {
            const orderId = '<%= order._id %>';

            const result = await Swal.fire({
                title: 'Cancel entire order?',
                text: "This will cancel all items in the order. This action cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#3b82f6',
                confirmButtonText: 'Yes, cancel order!'
            });

            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/<%= user._id %>/orders/${orderId}/cancel`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });

                    const data = await res.json();

                    if (data.success) {
                        await Swal.fire(
                            'Cancelled!',
                            'Your order has been cancelled successfully.',
                            'success'
                        );
                        location.reload();
                    } else {
                        Swal.fire(
                            'Failed!',
                            data.message || 'Failed to cancel order.',
                            'error'
                        );
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'An error occurred while cancelling the order.', 'error');
                }
            }
        }

        async function returnOrder() {
            const orderId = '<%= order._id %>';

            const { value: returnData } = await Swal.fire({
                title: 'Return Order',
                html: `
                    <div style="text-align: left;">
                        <label for="returnReason" style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 600;">Reason for Return</label>
                        <select id="returnReason" class="swal2-input" style="width: 100%; margin: 0 0 20px 0; display: block;">
                            <option value="">Select a reason</option>
                            <option value="Damaged product">Damaged product</option>
                            <option value="Different product received">Different product received</option>
                            <option value="Different color">Different color</option>
                            <option value="Size issue">Size issue</option>
                            <option value="Defective item">Defective item</option>
                            <option value="Other">Other</option>
                        </select>
                        <label for="customReason" style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 600;">Additional Details</label>
                        <textarea id="customReason" class="swal2-textarea" placeholder="Provide more details here..." style="width: 100%; margin: 0; display: block;"></textarea>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Submit Return Request',
                preConfirm: () => {
                    const reason = document.getElementById('returnReason').value;
                    const customText = document.getElementById('customReason').value.trim();
                    
                    if (!reason) {
                        Swal.showValidationMessage('Please select a reason for return');
                        return false;
                    }
                    
                    if (reason === 'Other' && (!customText || customText.length < 10)) {
                        Swal.showValidationMessage('Please provide at least 10 characters for "Other" reasons');
                        return false;
                    }

                    return { reason, customText };
                }
            });

            if (returnData) {
                const finalReason = returnData.reason === 'Other' 
                    ? returnData.customText 
                    : `${returnData.reason}${returnData.customText ? ': ' + returnData.customText : ''}`;

                try {
                    const res = await fetch(`/<%= user._id %>/orders/${orderId}/return`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ reason: finalReason })
                    });

                    const data = await res.json();

                    if (data.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Return Request Submitted',
                            text: 'Your return request has been submitted successfully. We will process it soon.',
                            confirmButtonColor: '#3b82f6'
                        });
                        location.reload();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Failed to submit return request.',
                            confirmButtonColor: '#3b82f6'
                        });
                    }

                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'An error occurred while submitting return request.', 'error');
                }
            }
        }

        async function returnItem(orderId, sku) {
            if (!orderId || !sku) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Data',
                    text: 'Could not find a valid order ID or item SKU.'
