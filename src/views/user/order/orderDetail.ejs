                        <select id="returnReason" class="swal2-input" style="width: 100%; margin: 0 0 20px 0; display: block;">
                            <option value="">Select a reason</option>
                            <option value="Damaged product">Damaged product</option>
                            <option value="Different product received">Different product received</option>
                            <option value="Different color">Different color</option>
                            <option value="Size issue">Size issue</option>
                            <option value="Defective item">Defective item</option>
                            <option value="Other">Other</option>
                        </select>
                        <label for="customReason" style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: 600;">Additional Details</label>
                        <textarea id="customReason" class="swal2-textarea" placeholder="Provide more details here..." style="width: 100%; margin: 0; display: block;"></textarea>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Submit Return Request',
                preConfirm: () => {
                    const reason = document.getElementById('returnReason').value;
                    const customText = document.getElementById('customReason').value.trim();
                    
                    if (!reason) {
                        Swal.showValidationMessage('Please select a reason for return');
                        return false;
                    }
                    
                    if (reason === 'Other' && (!customText || customText.length < 10)) {
                        Swal.showValidationMessage('Please provide at least 10 characters for "Other" reasons');
                        return false;
                    }

                    return { reason, customText };
                }
            });

            if (returnData) {
                const finalReason = returnData.reason === 'Other' 
                    ? returnData.customText 
                    : `${returnData.reason}${returnData.customText ? ': ' + returnData.customText : ''}`;

                try {
                    const res = await fetch(`/<%= user._id %>/orders/${orderId}/items/${sku}/return`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ reason: finalReason })
                    });

                    const data = await res.json();

                    if (data.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Return Request Submitted',
                            text: 'Your return request for this item has been submitted successfully.',
                            confirmButtonColor: '#3b82f6'
                        });
                        location.reload();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Failed to submit return request.',
                            confirmButtonColor: '#3b82f6'
                        });
                    }

                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'An error occurred while submitting return request.', 'error');
                }
            }
        }

        function downloadInvoice() {
            const orderId = '<%= order._id %>';
            window.open(`/<%= user._id %>/orders/${orderId}/invoice`, '_blank');
        }


    </script>
</body>
